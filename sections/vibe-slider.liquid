<section class="vibe-section" id="VibeSlider">

  <div class="container">
    <div class="section-header animate-on-scroll">
      <span class="section-label vibe-label">Discover</span>
      <h2 class="section-title vibe-title">{{ section.settings.title | default: 'Choose Your Vibe' }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>
  </div>

  <div class="vibe-slider-outer">

    {%- comment -%} Floating side arrows {%- endcomment -%}
    <button class="vibe-arrow vibe-arrow--prev slider-btn prev" aria-label="Previous slide">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
      </svg>
    </button>

    <div class="vibe-slider-clip">
      <div class="vibe-track">
        {%- for block in section.blocks -%}
          {%- liquid
            assign gc       = collections[block.settings.collection]
            assign card_img = block.settings.image
            if card_img == blank and gc != blank
              assign card_img = gc.image
            endif
            assign card_url  = block.settings.collection_url
            if card_url == blank and gc != blank
              assign card_url = gc.url
            endif
            if card_url == blank
              assign card_url = '/collections/all'
            endif
            assign card_name = block.settings.name
            if card_name == blank and gc != blank
              assign card_name = gc.title
            endif
            if card_name == blank
              assign card_name = 'Vibe'
            endif
          -%}
          <a
            href="{{ card_url }}"
            class="vibe-card"
            {{ block.shopify_attributes }}
          >
            <div
              class="vibe-card-frame"
              style="background: {{ block.settings.bg_color | default: '#1a1410' }};"
            >
              {%- if card_img != blank -%}
                <img
                  class="vibe-card-img"
                  src="{{ card_img | image_url: width: 400, format: 'webp' }}"
                  srcset="{{ card_img | image_url: width: 200, format: 'webp' }} 200w,
                          {{ card_img | image_url: width: 300, format: 'webp' }} 300w,
                          {{ card_img | image_url: width: 400, format: 'webp' }} 400w,
                          {{ card_img | image_url: width: 600, format: 'webp' }} 600w"
                  sizes="(max-width: 480px) 72vw, (max-width: 768px) 46vw, 260px"
                  alt="{{ card_img.alt | default: card_name }}"
                  width="260" height="360" loading="lazy"
                >
              {%- else -%}
                {{- 'collection-' | append: forloop.index | placeholder_svg_tag: 'vibe-card-img' -}}
              {%- endif -%}

              <div class="vibe-card-overlay">
                <div class="vibe-card-content">
                  <span class="vibe-card-name">{{ card_name }}</span>
                  <span class="vibe-card-cta">
                    Explore
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="13" height="13" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
                    </svg>
                  </span>
                </div>
              </div>
            </div>
          </a>
        {%- else -%}
          {%- assign default_vibes = 'Fresh,Fruity,Floral,Oud,Spicy,Woody,Musky' | split: ',' -%}
          {%- assign default_colors = '#1a2018,#201508,#1e1018,#2a1e0a,#221508,#181410,#1a1814' | split: ',' -%}
          {%- for vibe in default_vibes -%}
            <a href="{{ routes.collections_url }}/{{ vibe | downcase }}" class="vibe-card">
              <div class="vibe-card-frame" style="background: {{ default_colors[forloop.index0] }};">
                {{- 'collection-' | append: forloop.index | placeholder_svg_tag: 'vibe-card-img' -}}
                <div class="vibe-card-overlay">
                  <div class="vibe-card-content">
                    <span class="vibe-card-name">{{ vibe }}</span>
                    <span class="vibe-card-cta">
                      Explore
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="13" height="13" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
                      </svg>
                    </span>
                  </div>
                </div>
              </div>
            </a>
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>

    <button class="vibe-arrow vibe-arrow--next slider-btn next" aria-label="Next slide">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
      </svg>
    </button>

  </div>

    

</section>

{% schema %}
{
  "name": "Vibe Slider",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Choose Your Vibe"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Find the fragrance family that speaks to your soul"
    }
  ],
  "blocks": [
    {
      "type": "vibe_card",
      "name": "Vibe Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection",
          "info": "Image, title and URL are pulled automatically from the collection."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Override image (optional)",
          "info": "Leave blank to use the collection banner image."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Override label (optional)",
          "info": "Leave blank to use the collection title."
        },
        {
          "type": "url",
          "id": "collection_url",
          "label": "Override URL (optional)",
          "info": "Leave blank to use the collection URL."
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Fallback background colour",
          "default": "#1a1410"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Vibe Slider",
      "blocks": [
        { "type": "vibe_card", "settings": { "name": "Fresh",  "bg_color": "#D4ECD4" } },
        { "type": "vibe_card", "settings": { "name": "Fruity", "bg_color": "#FFE5CC" } },
        { "type": "vibe_card", "settings": { "name": "Floral", "bg_color": "#F5D5E8" } },
        { "type": "vibe_card", "settings": { "name": "Oud",    "bg_color": "#C8A882" } },
        { "type": "vibe_card", "settings": { "name": "Spicy",  "bg_color": "#E8C4A0" } },
        { "type": "vibe_card", "settings": { "name": "Woody",  "bg_color": "#C4A882" } },
        { "type": "vibe_card", "settings": { "name": "Musky",  "bg_color": "#E8DDD0" } }
      ]
    }
  ]
}
{% endschema %}
