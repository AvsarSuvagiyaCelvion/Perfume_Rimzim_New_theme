{% comment %}
  Section: Text Marquee
  Purpose: Infinite auto-scrolling text ticker strip
  Used in: Homepage, any custom landing page
  Metafield dependencies: none
{% endcomment %}

{%- liquid
  assign speed     = section.settings.speed | default: 30
  assign separator = section.settings.separator | default: '✦'
  assign bg_dark   = section.settings.dark_background
-%}

<section
  class="tmarquee{% if bg_dark %} tmarquee--dark{% endif %}"
  id="section-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="text-marquee"
  style="--tmarquee-speed: {{ speed }}s;"
>
  <div
    class="tmarquee__viewport"
    {% if section.settings.pause_on_hover %}data-pause-hover="true"{% endif %}
  >
    <div class="tmarquee__track" aria-hidden="true">
      {%- for pass in (1..2) -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'text_item' -%}
            <span class="tmarquee__item" {{ block.shopify_attributes }}>
              {{- block.settings.text | escape -}}
            </span>
            <span class="tmarquee__sep" aria-hidden="true">{{ separator }}</span>
          {%- endif -%}
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} Accessible static list for screen readers {%- endcomment -%}
  <ul class="visually-hidden">
    {%- for block in section.blocks -%}
      {%- if block.type == 'text_item' -%}
        <li>{{ block.settings.text | escape }}</li>
      {%- endif -%}
    {%- endfor -%}
  </ul>
</section>

<style>
  #section-{{ section.id }} {
    overflow: hidden;
    padding-block: var(--space-16);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  #section-{{ section.id }}.tmarquee--dark {
    background: var(--color-dark);
    border-color: transparent;
  }

  #section-{{ section.id }} .tmarquee__viewport {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
  }

  @media (prefers-reduced-motion: no-preference) {
    #section-{{ section.id }} .tmarquee__track {
      display: flex;
      align-items: center;
      width: max-content;
      white-space: nowrap;
      animation: tmarquee-scroll var(--tmarquee-speed) linear infinite;
    }

    #section-{{ section.id }} .tmarquee__viewport[data-pause-hover="true"]:hover .tmarquee__track {
      animation-play-state: paused;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #section-{{ section.id }} .tmarquee__track {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--space-16);
      white-space: normal;
    }
  }

  #section-{{ section.id }} .tmarquee__item {
    font-family: var(--font-heading);
    font-size: {{ section.settings.font_size }}px;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: {% if bg_dark %}var(--color-primary){% else %}var(--color-text){% endif %};
    padding-inline: var(--space-24);
  }

  #section-{{ section.id }}.tmarquee--dark .tmarquee__item {
    color: var(--color-primary);
  }

  #section-{{ section.id }} .tmarquee__sep {
    font-size: 0.6em;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  #section-{{ section.id }} .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
    list-style: none;
  }

  @keyframes tmarquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>

{% schema %}
{
  "name": "Text Marquee",
  "tag": "section",
  "class": "section-text-marquee",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "dark_background",
      "label": "Dark background",
      "default": false
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 28,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": false
    },
    {
      "type": "select",
      "id": "separator",
      "label": "Separator",
      "default": "✦",
      "options": [
        { "value": "✦", "label": "Star ✦" },
        { "value": "•", "label": "Dot •" },
        { "value": "◆", "label": "Diamond ◆" },
        { "value": "|", "label": "Pipe |" }
      ]
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "default": 30,
      "info": "Lower = faster. Higher = slower."
    }
  ],
  "blocks": [
    {
      "type": "text_item",
      "name": "Text item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Luxury Fragrances"
        }
      ]
    },
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "Text Marquee",
      "blocks": [
        { "type": "text_item", "settings": { "text": "Luxury Fragrances" } },
        { "type": "text_item", "settings": { "text": "Free Shipping Over $100" } },
        { "type": "text_item", "settings": { "text": "New Arrivals" } },
        { "type": "text_item", "settings": { "text": "Crafted with Passion" } }
      ]
    }
  ]
}
{% endschema %}
