<div class="trust-bar">
  <div class="container trust-bar-inner">

    <div class="trust-item">
      <div class="trust-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/></svg>
      </div>
      <div class="trust-text">
        <span class="trust-title">{{ section.settings.trust1_title | default: 'Free Shipping' }}</span>
        <span class="trust-sub">{{ section.settings.trust1_sub | default: 'On orders above ₹999' }}</span>
      </div>
    </div>

    <div class="trust-divider"></div>

    <div class="trust-item">
      <div class="trust-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
      </div>
      <div class="trust-text">
        <span class="trust-title">{{ section.settings.trust2_title | default: '100% Authentic' }}</span>
        <span class="trust-sub">{{ section.settings.trust2_sub | default: 'Genuine products guaranteed' }}</span>
      </div>
    </div>

    <div class="trust-divider"></div>

    <div class="trust-item">
      <div class="trust-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3"/></svg>
      </div>
      <div class="trust-text">
        <span class="trust-title">{{ section.settings.trust3_title | default: 'Easy Returns' }}</span>
        <span class="trust-sub">{{ section.settings.trust3_sub | default: '7-day hassle-free returns' }}</span>
      </div>
    </div>

    <div class="trust-divider"></div>

    <div class="trust-item">
      <div class="trust-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
      </div>
      <div class="trust-text">
        <span class="trust-title">{{ section.settings.trust4_title | default: 'Secure Payments' }}</span>
        <span class="trust-sub">{{ section.settings.trust4_sub | default: 'SSL encrypted checkout' }}</span>
      </div>
    </div>

  </div>
</div>

{% style %}
.trust-bar {
  background: var(--color-dark);
  border-top: 1px solid rgba(255,255,255,0.06);
  border-bottom: 1px solid rgba(255,255,255,0.06);
  padding: 20px 0;
}
.trust-bar-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  flex-wrap: wrap;
}
.trust-item {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 12px 32px;
  flex: 1;
  min-width: 180px;
  justify-content: center;
}
.trust-icon {
  width: 40px; height: 40px;
  border-radius: 50%;
  background: rgba(201,169,110,0.1);
  border: 1px solid rgba(201,169,110,0.25);
  display: flex; align-items: center; justify-content: center;
  color: var(--color-primary);
  flex-shrink: 0;
}
.trust-icon svg { width: 18px; height: 18px; }
.trust-text { display: flex; flex-direction: column; gap: 2px; }
.trust-title {
  font-size: 0.85rem;
  font-weight: 600;
  color: #fff;
  letter-spacing: 0.02em;
}
.trust-sub {
  font-size: 0.72rem;
  color: rgba(255,255,255,0.45);
}
.trust-divider {
  width: 1px;
  height: 40px;
  background: rgba(255,255,255,0.1);
  flex-shrink: 0;
}
@media (max-width: 768px) {
  .trust-bar-inner { gap: 0; }
  .trust-item { padding: 12px 16px; min-width: 140px; }
  .trust-divider { display: none; }
}
@media (max-width: 480px) {
  .trust-bar-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding: 4px 0;
  }
  .trust-item {
    width: auto;
    justify-content: flex-start;
    padding: 14px 12px;
    border-right: 1px solid rgba(255,255,255,0.06);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  /* Right column: items 2 and 4 (nth-child counts hidden dividers) */
  .trust-item:nth-child(3),
  .trust-item:nth-child(7) {
    border-right: none;
  }
  /* Bottom row: items 3 and 4 */
  .trust-item:nth-child(5),
  .trust-item:nth-child(7) {
    border-bottom: none;
  }
}
{% endstyle %}

{% schema %}
{
  "name": "Trust Bar",
  "settings": [
    { "type": "text", "id": "trust1_title", "label": "Item 1 title", "default": "Free Shipping" },
    { "type": "text", "id": "trust1_sub",   "label": "Item 1 subtitle", "default": "On orders above ₹999" },
    { "type": "text", "id": "trust2_title", "label": "Item 2 title", "default": "100% Authentic" },
    { "type": "text", "id": "trust2_sub",   "label": "Item 2 subtitle", "default": "Genuine products guaranteed" },
    { "type": "text", "id": "trust3_title", "label": "Item 3 title", "default": "Easy Returns" },
    { "type": "text", "id": "trust3_sub",   "label": "Item 3 subtitle", "default": "7-day hassle-free returns" },
    { "type": "text", "id": "trust4_title", "label": "Item 4 title", "default": "Secure Payments" },
    { "type": "text", "id": "trust4_sub",   "label": "Item 4 subtitle", "default": "SSL encrypted checkout" }
  ],
  "presets": [{ "name": "Trust Bar" }]
}
{% endschema %}
