<div class="cart-page" id="CartPage">
  <div class="container">

    <div class="cart-page-header">
      <h1 class="cart-page-title">Your Cart</h1>
      {%- if cart.item_count > 0 -%}
        <span class="cart-page-count">{{ cart.item_count }} item{{ cart.item_count | pluralize: '', 's' }}</span>
      {%- endif -%}
    </div>

    {%- if cart.item_count == 0 -%}

      <div class="cart-empty">
        <div class="cart-empty-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007z"/>
          </svg>
        </div>
        <h2 class="cart-empty-heading">Your cart is empty</h2>
        <p class="cart-empty-sub">Discover our curated collection of fragrances.</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary">Continue Shopping</a>
      </div>

    {%- else -%}

      <div class="cart-layout">

        {%- comment -%} ── Items ── {%- endcomment -%}
        <div class="cart-items-col">
          {%- form 'cart', cart, id: 'CartForm', class: 'cart-form' -%}

            <div class="cart-items-list" id="CartItemsList">
              {%- for item in cart.items -%}
                <div class="cart-item" data-key="{{ item.key }}">

                  {%- comment -%} Thumbnail {%- endcomment -%}
                  <a href="{{ item.url }}" class="cart-item-img-link">
                    {%- if item.image != blank -%}
                      <img
                        src="{{ item.image | image_url: width: 200 }}"
                        alt="{{ item.image.alt | default: item.title | escape }}"
                        class="cart-item-img"
                        width="100" height="133" loading="lazy"
                      >
                    {%- else -%}
                      {{- 'product-1' | placeholder_svg_tag: 'cart-item-img' -}}
                    {%- endif -%}
                  </a>

                  {%- comment -%} Info {%- endcomment -%}
                  <div class="cart-item-info">
                    <a href="{{ item.url }}" class="cart-item-title">{{ item.product.title }}</a>
                    {%- unless item.variant.title == 'Default Title' -%}
                      <p class="cart-item-variant">{{ item.variant.title }}</p>
                    {%- endunless -%}
                    <p class="cart-item-price">{{ item.price | money }}</p>

                    {%- comment -%} Qty stepper {%- endcomment -%}
                    <div class="cart-item-qty">
                      <button
                        type="button"
                        class="cart-qty-btn cart-qty-minus"
                        aria-label="Decrease quantity"
                        data-key="{{ item.key }}"
                        data-action="minus"
                      >−</button>
                      <input
                        type="number"
                        name="updates[{{ item.key }}]"
                        class="cart-qty-input"
                        value="{{ item.quantity }}"
                        min="0"
                        aria-label="Quantity for {{ item.title | escape }}"
                        data-key="{{ item.key }}"
                      >
                      <button
                        type="button"
                        class="cart-qty-btn cart-qty-plus"
                        aria-label="Increase quantity"
                        data-key="{{ item.key }}"
                        data-action="plus"
                      >+</button>
                    </div>
                  </div>

                  {%- comment -%} Line total + remove {%- endcomment -%}
                  <div class="cart-item-right">
                    <span class="cart-item-line-price">{{ item.line_price | money }}</span>
                    <button
                      type="button"
                      class="cart-item-remove"
                      aria-label="Remove {{ item.title | escape }}"
                      data-key="{{ item.key }}"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                      </svg>
                    </button>
                  </div>

                </div>
              {%- endfor -%}
            </div>

          {%- endform -%}
        </div>

        {%- comment -%} ── Summary ── {%- endcomment -%}
        <div class="cart-summary-col">
          <div class="cart-summary" id="CartSummary">
            <h2 class="cart-summary-title">Order Summary</h2>

            <div class="cart-summary-row">
              <span>Subtotal</span>
              <span class="cart-subtotal-price" id="CartSubtotal">{{ cart.total_price | money }}</span>
            </div>

            <p class="cart-shipping-note">Shipping and taxes calculated at checkout.</p>

            {%- if cart.cart_level_discount_applications.size > 0 -%}
              {%- for discount in cart.cart_level_discount_applications -%}
                <div class="cart-summary-row cart-discount-row">
                  <span>{{ discount.title }}</span>
                  <span class="cart-discount-value">−{{ discount.total_allocated_amount | money }}</span>
                </div>
              {%- endfor -%}
            {%- endif -%}

            <div class="cart-summary-divider"></div>

            <div class="cart-summary-row cart-total-row">
              <span>Total</span>
              <span class="cart-total-price" id="CartTotal">{{ cart.total_price | money }}</span>
            </div>

            <a href="/checkout" class="btn btn-primary cart-checkout-btn">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" width="18" height="18" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
              </svg>
              Proceed to Checkout
            </a>

            <a href="{{ routes.all_products_collection_url }}" class="cart-continue-link">← Continue Shopping</a>
          </div>
        </div>

      </div>

    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}
