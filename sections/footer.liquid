<footer class="site-footer" id="SiteFooter" role="contentinfo">
  <div class="container">
    <div class="footer-body">

      {%- comment -%} ── Brand Column ── {%- endcomment -%}
      <div class="footer-brand">
        <a href="{{ routes.root_url }}" class="footer-logo-link" aria-label="{{ shop.name }}">
          {%- if section.settings.logo != blank -%}
            <img
              class="footer-logo-img"
              src="{{ section.settings.logo | image_url: width: 240 }}"
              alt="{{ section.settings.logo.alt | default: shop.name }}"
              width="160" height="52" loading="lazy"
            >
          {%- else -%}
            <span class="logo-text footer-logo-text">
              {{ section.settings.brand_name | default: shop.name }}
              <span class="logo-sub">{{ section.settings.tagline | default: 'Luxury Perfumes' }}</span>
            </span>
          {%- endif -%}
        </a>

        <p class="footer-brand-desc">
          {{ section.settings.about_text | default: 'We craft luxury fragrances that tell stories. Each bottle is a masterpiece — a blend of rare ingredients and passionate artistry for those who seek the extraordinary.' }}
        </p>

        <div class="footer-social" aria-label="Social media links">

          {%- if section.settings.instagram_url != blank -%}
            <a href="{{ section.settings.instagram_url }}" class="footer-social-link" aria-label="Instagram" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </a>
          {%- endif -%}

          {%- if section.settings.facebook_url != blank -%}
            <a href="{{ section.settings.facebook_url }}" class="footer-social-link" aria-label="Facebook" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
          {%- endif -%}

          {%- if section.settings.twitter_url != blank -%}
            <a href="{{ section.settings.twitter_url }}" class="footer-social-link" aria-label="X / Twitter" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
          {%- endif -%}

          {%- if section.settings.pinterest_url != blank -%}
            <a href="{{ section.settings.pinterest_url }}" class="footer-social-link" aria-label="Pinterest" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
              </svg>
            </a>
          {%- endif -%}

          {%- if section.settings.youtube_url != blank -%}
            <a href="{{ section.settings.youtube_url }}" class="footer-social-link" aria-label="YouTube" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
            </a>
          {%- endif -%}

        </div>
      </div>

      {%- comment -%} ── Quick Links ── {%- endcomment -%}
      <div class="footer-col">
        <h3 class="footer-col-title">Quick Links</h3>
        <ul class="footer-links">
          {%- for link in linklists[section.settings.quick_links_menu].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- else -%}
            <li><a href="/">Home</a></li>
            <li><a href="/collections">All Collections</a></li>
            <li><a href="/collections/new-arrivals">New Arrivals</a></li>
            <li><a href="/blogs/journal">Our Journal</a></li>
            <li><a href="/pages/about">About Us</a></li>
            <li><a href="/pages/store-locator">Store Locator</a></li>
          {%- endfor -%}
        </ul>
      </div>

      {%- comment -%} ── Customer Support ── {%- endcomment -%}
      <div class="footer-col">
        <h3 class="footer-col-title">Customer Support</h3>
        <ul class="footer-links">
          {%- for link in linklists[section.settings.support_links_menu].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- else -%}
            <li><a href="/pages/contact">Contact Us</a></li>
            <li><a href="/pages/faq">FAQs</a></li>
            <li><a href="/pages/shipping-returns">Shipping &amp; Returns</a></li>
            <li><a href="/pages/track-order">Track Your Order</a></li>
            <li><a href="/pages/size-guide">Fragrance Guide</a></li>
            <li><a href="/pages/gift-wrapping">Gift Wrapping</a></li>
          {%- endfor -%}
        </ul>
      </div>

      {%- comment -%} ── Contact Info ── {%- endcomment -%}
      <div class="footer-col">
        <h3 class="footer-col-title">Get in Touch</h3>
        <ul class="footer-links">
          {%- if section.settings.contact_email != blank -%}
            <li>
              <a href="mailto:{{ section.settings.contact_email }}">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="14" height="14">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
                </svg>
                {{ section.settings.contact_email }}
              </a>
            </li>
          {%- endif -%}
          {%- if section.settings.contact_phone != blank -%}
            <li>
              <a href="tel:{{ section.settings.contact_phone | remove: ' ' }}">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="14" height="14">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
                </svg>
                {{ section.settings.contact_phone }}
              </a>
            </li>
          {%- endif -%}
          {%- if section.settings.contact_hours != blank -%}
            <li>
              <span style="color:rgba(255,255,255,0.30); font-size:0.75rem; letter-spacing:1px;">{{ section.settings.contact_hours }}</span>
            </li>
          {%- endif -%}
          <li><a href="/pages/contact">Send a Message →</a></li>
        </ul>
      </div>

    </div>

    {%- comment -%} ── Footer Bottom ── {%- endcomment -%}
    <div class="footer-bottom">
      <p class="footer-copy">
        &copy; {{ 'now' | date: '%Y' }}
        <a href="{{ routes.root_url }}">{{ shop.name }}</a>.
        All rights reserved.
      </p>
      <nav class="footer-legal" aria-label="Legal links">
        <a href="{{ shop.privacy_policy.url }}">Privacy Policy</a>
        <a href="{{ shop.terms_of_service.url }}">Terms of Service</a>
        <a href="{{ shop.refund_policy.url }}">Refund Policy</a>
      </nav>
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name (fallback if no logo)",
      "default": "LUMIÈRE"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Luxury Perfumes"
    },
    {
      "type": "textarea",
      "id": "about_text",
      "label": "Brand description",
      "default": "We craft luxury fragrances that tell stories. Each bottle is a masterpiece — a blend of rare ingredients and passionate artistry for those who seek the extraordinary."
    },
    {
      "type": "header",
      "content": "Navigation Menus"
    },
    {
      "type": "link_list",
      "id": "quick_links_menu",
      "label": "Quick links menu",
      "default": "footer"
    },
    {
      "type": "link_list",
      "id": "support_links_menu",
      "label": "Support links menu"
    },
    {
      "type": "header",
      "content": "Contact"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Email address"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Phone number"
    },
    {
      "type": "text",
      "id": "contact_hours",
      "label": "Business hours",
      "default": "Mon – Sat: 9am – 6pm"
    },
    {
      "type": "header",
      "content": "Social Media"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "twitter_url",
      "label": "X / Twitter URL"
    },
    {
      "type": "url",
      "id": "pinterest_url",
      "label": "Pinterest URL"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube URL"
    }
  ]
}
{% endschema %}
