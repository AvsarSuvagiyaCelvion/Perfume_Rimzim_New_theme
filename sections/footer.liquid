<footer class="site-footer" id="SiteFooter" role="contentinfo">

  <div class="footer-mist" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1400 420" preserveAspectRatio="xMidYMid slice">
      <defs>
        <radialGradient id="fm1" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="white" stop-opacity="0.055"/>
          <stop offset="100%" stop-color="white" stop-opacity="0"/>
        </radialGradient>
        <radialGradient id="fm2" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="white" stop-opacity="0.035"/>
          <stop offset="100%" stop-color="white" stop-opacity="0"/>
        </radialGradient>
        <radialGradient id="fg1" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="rgb(201,169,110)" stop-opacity="0.09"/>
          <stop offset="100%" stop-color="rgb(201,169,110)" stop-opacity="0"/>
        </radialGradient>
      </defs>

      <!-- Atmospheric mist clouds -->
      <ellipse cx="200" cy="120" rx="360" ry="200" fill="url(#fm1)"/>
      <ellipse cx="700" cy="200" rx="620" ry="210" fill="url(#fm2)"/>
      <ellipse cx="1150" cy="145" rx="340" ry="185" fill="url(#fm1)"/>
      <ellipse cx="1360" cy="360" rx="260" ry="180" fill="url(#fg1)"/>

      <!-- Cluster 1 — upper right spray -->
      <circle cx="870" cy="38" r="2.5" fill="white" opacity=".52"/>
      <circle cx="910" cy="22" r="1.8" fill="white" opacity=".42"/>
      <circle cx="840" cy="62" r="2"   fill="white" opacity=".45"/>
      <circle cx="950" cy="48" r="1.5" fill="white" opacity=".38"/>
      <circle cx="990" cy="28" r="1.2" fill="white" opacity=".3"/>
      <circle cx="920" cy="82" r="1"   fill="white" opacity=".25"/>
      <circle cx="875" cy="18" r="1"   fill="white" opacity=".4"/>
      <circle cx="1032" cy="55" r="1.5" fill="white" opacity=".22"/>
      <circle cx="1062" cy="35" r="0.8" fill="white" opacity=".18"/>
      <circle cx="800" cy="88" r="1.2" fill="white" opacity=".2"/>
      <circle cx="962" cy="105" r="1"  fill="white" opacity=".18"/>

      <!-- Cluster 2 — upper left -->
      <circle cx="110" cy="50" r="2.2" fill="white" opacity=".42"/>
      <circle cx="155" cy="28" r="1.5" fill="white" opacity=".35"/>
      <circle cx="75"  cy="72" r="1.8" fill="white" opacity=".32"/>
      <circle cx="195" cy="58" r="1.2" fill="white" opacity=".3"/>
      <circle cx="135" cy="88" r="1"   fill="white" opacity=".22"/>
      <circle cx="230" cy="40" r="1.8" fill="white" opacity=".32"/>
      <circle cx="175" cy="108" r="0.8" fill="white" opacity=".18"/>
      <circle cx="55"  cy="95" r="1"   fill="white" opacity=".2"/>
      <circle cx="268" cy="78" r="1"   fill="white" opacity=".18"/>
      <circle cx="312" cy="55" r="1.2" fill="white" opacity=".2"/>

      <!-- Cluster 3 — centre upper -->
      <circle cx="565" cy="44" r="1.8" fill="white" opacity=".32"/>
      <circle cx="610" cy="26" r="1.2" fill="white" opacity=".28"/>
      <circle cx="525" cy="68" r="2"   fill="white" opacity=".35"/>
      <circle cx="650" cy="58" r="1"   fill="white" opacity=".24"/>
      <circle cx="590" cy="90" r="1.2" fill="white" opacity=".2"/>
      <circle cx="675" cy="82" r="1.5" fill="white" opacity=".18"/>

      <!-- Dispersed mid-layer -->
      <circle cx="340" cy="95"  r="1"   fill="white" opacity=".18"/>
      <circle cx="415" cy="68"  r="1.2" fill="white" opacity=".2"/>
      <circle cx="455" cy="128" r="0.8" fill="white" opacity=".15"/>
      <circle cx="740" cy="105" r="1.2" fill="white" opacity=".18"/>
      <circle cx="795" cy="65"  r="1"   fill="white" opacity=".2"/>
      <circle cx="1092" cy="85" r="1.5" fill="white" opacity=".2"/>
      <circle cx="1148" cy="52" r="1"   fill="white" opacity=".18"/>
      <circle cx="1200" cy="78" r="1.2" fill="white" opacity=".16"/>
      <circle cx="1268" cy="108" r="0.8" fill="white" opacity=".14"/>
      <circle cx="1318" cy="62" r="1"   fill="white" opacity=".18"/>
      <circle cx="1362" cy="92" r="0.8" fill="white" opacity=".12"/>

      <!-- Lower settling mist -->
      <circle cx="185" cy="195" r="0.8" fill="white" opacity=".1"/>
      <circle cx="368" cy="218" r="1"   fill="white" opacity=".1"/>
      <circle cx="542" cy="245" r="0.8" fill="white" opacity=".08"/>
      <circle cx="718" cy="178" r="1"   fill="white" opacity=".1"/>
      <circle cx="892" cy="228" r="0.8" fill="white" opacity=".08"/>
      <circle cx="1048" cy="198" r="1"  fill="white" opacity=".1"/>
      <circle cx="1242" cy="238" r="0.8" fill="white" opacity=".08"/>
      <circle cx="320" cy="295" r="0.8" fill="white" opacity=".06"/>
      <circle cx="652" cy="318" r="0.8" fill="white" opacity=".06"/>
      <circle cx="1105" cy="308" r="0.8" fill="white" opacity=".06"/>

      <!-- Golden accent particles -->
      <circle cx="942" cy="158" r="1.5" fill="rgb(201,169,110)" opacity=".28"/>
      <circle cx="972" cy="140" r="1"   fill="rgb(201,169,110)" opacity=".22"/>
      <circle cx="878" cy="168" r="0.8" fill="rgb(201,169,110)" opacity=".18"/>
      <circle cx="1018" cy="152" r="1.2" fill="rgb(201,169,110)" opacity=".2"/>
      <circle cx="198" cy="145" r="1"   fill="rgb(201,169,110)" opacity=".18"/>
      <circle cx="162" cy="162" r="0.8" fill="rgb(201,169,110)" opacity=".15"/>
    </svg>
  </div>

  <div class="container">
    <div class="footer-body">

      {%- comment -%} ── Brand Column ── {%- endcomment -%}
      <div class="footer-brand">
        <a href="{{ routes.root_url }}" class="footer-logo-link" aria-label="{{ shop.name }}">
          {%- if section.settings.logo != blank -%}
            <img
              class="footer-logo-img"
              src="{{ section.settings.logo | image_url: width: 240 }}"
              alt="{{ section.settings.logo.alt | default: shop.name }}"
              width="160" height="52" loading="lazy"
            >
          {%- else -%}
            <span class="logo-text footer-logo-text">
              {{ section.settings.brand_name | default: shop.name }}
              <span class="logo-sub">{{ section.settings.tagline | default: 'Luxury Perfumes' }}</span>
            </span>
          {%- endif -%}
        </a>

        <p class="footer-brand-desc">
          {{ section.settings.about_text | default: 'We craft luxury fragrances that tell stories. Each bottle is a masterpiece — a blend of rare ingredients and passionate artistry for those who seek the extraordinary.' }}
        </p>

        {%- if section.settings.instagram_url != blank or section.settings.facebook_url != blank or section.settings.twitter_url != blank or section.settings.pinterest_url != blank or section.settings.youtube_url != blank -%}
        <div class="footer-social" role="list" aria-label="Social media links">

          {%- if section.settings.instagram_url != blank -%}
            <a href="{{ section.settings.instagram_url }}" class="footer-social-link" aria-label="Instagram" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </a>
          {%- endif -%}

          {%- if section.settings.facebook_url != blank -%}
            <a href="{{ section.settings.facebook_url }}" class="footer-social-link" aria-label="Facebook" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
          {%- endif -%}

          {%- if section.settings.twitter_url != blank -%}
            <a href="{{ section.settings.twitter_url }}" class="footer-social-link" aria-label="X / Twitter" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
          {%- endif -%}

          {%- if section.settings.pinterest_url != blank -%}
            <a href="{{ section.settings.pinterest_url }}" class="footer-social-link" aria-label="Pinterest" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
              </svg>
            </a>
          {%- endif -%}

          {%- if section.settings.youtube_url != blank -%}
            <a href="{{ section.settings.youtube_url }}" class="footer-social-link" aria-label="YouTube" target="_blank" rel="noopener">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
            </a>
          {%- endif -%}

        </div>
        {%- endif -%}
      </div>

      {%- comment -%} ── Col 2: Shop By Category (main menu) ── {%- endcomment -%}
      <div class="footer-col footer-col--accordion">
        <button class="footer-col-title footer-accordion-btn" aria-expanded="false">
          Shop By Category
          <svg class="footer-accordion-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
          </svg>
        </button>
        <ul class="footer-links footer-accordion-body">
          {%- for link in linklists[section.settings.category_menu].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- else -%}
            <li><a href="{{ routes.all_products_collection_url }}">All Fragrances</a></li>
            <li><a href="{{ routes.collections_url }}/new-arrivals">New Arrivals</a></li>
            <li><a href="{{ routes.collections_url }}/best-sellers">Best Sellers</a></li>
            <li><a href="{{ routes.collections_url }}/gift-sets">Gift Sets</a></li>
          {%- endfor -%}
        </ul>
      </div>

      {%- comment -%} ── Col 3: My Account ── {%- endcomment -%}
      <div class="footer-col footer-col--accordion">
        <button class="footer-col-title footer-accordion-btn" aria-expanded="false">
          My Account
          <svg class="footer-accordion-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
          </svg>
        </button>
        <ul class="footer-links footer-accordion-body">
          {%- if customer -%}
            <li><a href="{{ routes.account_url }}">My Account</a></li>
            <li><a href="{{ routes.account_orders_url }}">My Orders</a></li>
            <li><a href="{{ routes.account_addresses_url }}">My Addresses</a></li>
            <li><a href="{{ routes.account_logout_url }}">Logout</a></li>
          {%- endif -%}
          <li><a href="/pages/wishlist">My Wishlist</a></li>
          <li><a href="{{ routes.cart_url }}">My Cart</a></li>
          <li><a href="/pages/contact">Track My Order</a></li>
        </ul>
      </div>

      {%- comment -%} ── Col 4: Our Policies ── {%- endcomment -%}
      <div class="footer-col footer-col--accordion">
        <button class="footer-col-title footer-accordion-btn" aria-expanded="false">
          Our Policies
          <svg class="footer-accordion-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
          </svg>
        </button>
        <ul class="footer-links footer-accordion-body">
          {%- for link in linklists[section.settings.policies_menu].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- else -%}
            <li><a href="{{ shop.privacy_policy.url }}">Privacy Policy</a></li>
            <li><a href="{{ shop.refund_policy.url }}">Refund Policy</a></li>
            <li><a href="{{ shop.terms_of_service.url }}">Terms of Service</a></li>
            <li><a href="{{ shop.shipping_policy.url }}">Shipping Policy</a></li>
          {%- endfor -%}
        </ul>
      </div>

    </div>

    {%- comment -%} ── Footer Bottom ── {%- endcomment -%}
      <div class="footer-bottom">
      <p class="footer-copy">
        &copy; {{ 'now' | date: '%Y' }}
        <a href="{{ routes.root_url }}">{{ shop.name }}</a>.
        All rights reserved.
      </p>
      <nav class="footer-legal" aria-label="Legal links">
        <a href="{{ shop.privacy_policy.url }}">Privacy Policy</a>
        <a href="{{ shop.terms_of_service.url }}">Terms of Service</a>
        <a href="{{ shop.refund_policy.url }}">Refund Policy</a>
      </nav>
    </div>  

  </div>
</footer>

<script>
(function () {
  function initFooterAccordion() {
    if (window.innerWidth > 768) return;
    document.querySelectorAll('.footer-accordion-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', !expanded);
      });
    });
  }
  document.addEventListener('DOMContentLoaded', initFooterAccordion);
})();
</script>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name (fallback if no logo)",
      "default": "LUMIÈRE"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Luxury Perfumes"
    },
    {
      "type": "textarea",
      "id": "about_text",
      "label": "Brand description",
      "default": "We craft luxury fragrances that tell stories. Each bottle is a masterpiece — a blend of rare ingredients and passionate artistry for those who seek the extraordinary."
    },
    {
      "type": "header",
      "content": "Navigation Menus"
    },
    {
      "type": "link_list",
      "id": "category_menu",
      "label": "Shop By Category menu",
      "default": "main-menu",
      "info": "Select your main navigation menu to show categories"
    },
    {
      "type": "link_list",
      "id": "policies_menu",
      "label": "Our Policies menu",
      "info": "Create a menu in Navigation named 'Policies' and link your policy pages"
    },
    {
      "type": "header",
      "content": "Social Media"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "twitter_url",
      "label": "X / Twitter URL"
    },
    {
      "type": "url",
      "id": "pinterest_url",
      "label": "Pinterest URL"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube URL"
    }
  ]
}
{% endschema %}
