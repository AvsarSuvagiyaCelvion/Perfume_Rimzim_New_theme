{% comment %}
  Section: Product Marquee
  Purpose: Infinite auto-scrolling horizontal strip of product cards
  Used in: Homepage, any custom landing page
  Metafield dependencies: none
{% endcomment %}

{%- liquid
  assign heading     = section.settings.heading
  assign speed       = section.settings.speed | default: 40
  assign pause_hover = section.settings.pause_on_hover
  assign products    = section.settings.products
-%}

<section
  class="pmarquee"
  id="section-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="product-marquee"
  style="--marquee-speed: {{ speed }}s;"
>
  {%- if heading != blank -%}
    <div class="pmarquee__header">
      <h2 class="pmarquee__heading">{{ heading | escape }}</h2>
    </div>
  {%- endif -%}

  <div
    class="pmarquee__viewport"
    {% if pause_hover %}data-pause-hover="true"{% endif %}
  >
    <div class="pmarquee__track">
      {%- for pass in (1..2) -%}
        {%- for product in products -%}
          {%- liquid
            if product.images.size > 2
              assign primary_img = product.images[2]
              assign hover_img   = product.images[1]
            elsif product.images.size > 1
              assign primary_img = product.featured_image
              assign hover_img   = product.images[1]
            else
              assign primary_img = product.featured_image
              assign hover_img   = nil
            endif
          -%}
          <a
            href="{{ product.url }}"
            class="pmarquee__card"
            {%- if pass == 1 -%}
              aria-label="{{ product.title | escape }}"
            {%- else -%}
              aria-hidden="true" tabindex="-1"
            {%- endif -%}
          >
            <div class="pmarquee__media">
              {%- if primary_img != blank -%}
                <img
                  class="pmarquee__img"
                  src="{{ primary_img | image_url: width: 400, format: 'webp' }}"
                  alt="{% if pass == 1 %}{{ primary_img.alt | default: product.title | escape }}{% endif %}"
                  width="400" height="400"
                  loading="lazy"
                >
                {%- if hover_img != blank -%}
                  <img
                    class="pmarquee__img pmarquee__img--hover"
                    src="{{ hover_img | image_url: width: 400, format: 'webp' }}"
                    alt=""
                    width="400" height="400"
                    loading="lazy"
                    aria-hidden="true"
                  >
                {%- endif -%}
              {%- else -%}
                {{- 'product-1' | placeholder_svg_tag: 'pmarquee__img' -}}
              {%- endif -%}
            </div>
            <div class="pmarquee__info">
              <p class="pmarquee__name">{{ product.title }}</p>
              <p class="pmarquee__price">{{ product.price | money }}</p>
            </div>
          </a>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #section-{{ section.id }} {
    padding-block: var(--space-48);
    overflow: hidden;
    background: var(--color-bg);
  }

  #section-{{ section.id }} .pmarquee__header {
    text-align: center;
    margin-bottom: var(--space-32);
  }

  #section-{{ section.id }} .pmarquee__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 400;
    color: var(--color-text);
    letter-spacing: 0.02em;
    margin: 0;
  }

  #section-{{ section.id }} .pmarquee__viewport {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
  }

  @media (prefers-reduced-motion: no-preference) {
    #section-{{ section.id }} .pmarquee__track {
      display: flex;
      gap: var(--space-20);
      width: max-content;
      animation: pmarquee-scroll var(--marquee-speed) linear infinite;
    }

    #section-{{ section.id }} .pmarquee__viewport[data-pause-hover="true"]:hover .pmarquee__track {
      animation-play-state: paused;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #section-{{ section.id }} .pmarquee__track {
      display: flex;
      gap: var(--space-20);
      flex-wrap: wrap;
      justify-content: center;
    }

    #section-{{ section.id }} .pmarquee__card[aria-hidden="true"] {
      display: none;
    }
  }

  #section-{{ section.id }} .pmarquee__card {
    display: block;
    text-decoration: none;
    flex-shrink: 0;
    width: 220px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-bg-cream);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #section-{{ section.id }} .pmarquee__card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
  }

  #section-{{ section.id }} .pmarquee__media {
    position: relative;
    width: 220px;
    height: 220px;
    overflow: hidden;
  }

  #section-{{ section.id }} .pmarquee__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.4s ease;
  }

  #section-{{ section.id }} .pmarquee__img--hover {
    opacity: 0;
  }

  #section-{{ section.id }} .pmarquee__card:hover .pmarquee__img:not(.pmarquee__img--hover) {
    opacity: 0;
  }

  #section-{{ section.id }} .pmarquee__card:hover .pmarquee__img--hover {
    opacity: 1;
  }

  #section-{{ section.id }} .pmarquee__info {
    padding: var(--space-12) var(--space-16) var(--space-16);
  }

  #section-{{ section.id }} .pmarquee__name {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    color: var(--color-text);
    margin: 0 0 var(--space-4);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    letter-spacing: 0.01em;
  }

  #section-{{ section.id }} .pmarquee__price {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-primary);
    margin: 0;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  @keyframes pmarquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>

{% schema %}
{
  "name": "Product Marquee",
  "tag": "section",
  "class": "section-product-marquee",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Fragrances"
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Products",
      "limit": 12
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "s",
      "default": 40,
      "info": "Lower = faster. Higher = slower."
    }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "Product Marquee"
    }
  ]
}
{% endschema %}
