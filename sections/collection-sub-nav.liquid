{%- if section.blocks.size > 0 -%}
<section class="csn-section" id="CollectionSubNav-{{ section.id }}">
  <div class="csn-container">

    {%- if section.settings.heading != blank -%}
      <div class="csn-header">
        {%- if section.settings.eyebrow != blank -%}
          <span class="csn-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="csn-heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="csn-subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="csn-grid csn-grid--{{ section.blocks.size | at_most: 4 }}">
      {%- for block in section.blocks -%}
        {%- liquid
          assign col       = collections[block.settings.collection]
          assign col_title = block.settings.title | default: col.title
          assign col_desc  = block.settings.description | default: col.description | strip_html | truncate: 80
          assign col_url   = col.url | default: block.settings.fallback_url | default: routes.all_products_collection_url
          assign col_img   = block.settings.image | default: col.featured_image
        -%}
        <a
          href="{{ col_url }}"
          class="csn-card"
          aria-label="{{ col_title | escape }}"
          {{ block.shopify_attributes }}
        >
          <div class="csn-card-img">
            {%- if col_img != blank -%}
              <img
                src="{{ col_img | image_url: width: 700, format: 'webp' }}"
                alt="{{ col_img.alt | default: col_title | escape }}"
                loading="lazy"
                width="700"
                height="500"
              >
            {%- else -%}
              <div class="csn-card-placeholder" aria-hidden="true"></div>
            {%- endif -%}
            <div class="csn-card-overlay"></div>
          </div>

          <div class="csn-card-body">
            <h3 class="csn-card-title">{{ col_title }}</h3>
            {%- if col_desc != blank -%}
              <p class="csn-card-desc">{{ col_desc }}</p>
            {%- endif -%}
            <span class="csn-card-cta">
              Explore
              <svg width="14" height="7" viewBox="0 0 14 7" fill="none" aria-hidden="true">
                <path d="M10.5 0.5L13.5 3.5M13.5 3.5L10.5 6.5M13.5 3.5H0.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>
        </a>
      {%- endfor -%}
    </div>

  </div>
</section>
{%- endif -%}

{% style %}

#CollectionSubNav-{{ section.id }} {
  --csn-gold:  #c5a059;
  --csn-dark:  #1a1a1a;
  --csn-cream: #f9f7f2;
}

.csn-section {
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  background: var(--csn-cream);
}

.csn-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 40px;
}

/* ── Header ── */
.csn-header {
  text-align: center;
  margin-bottom: 52px;
}

.csn-eyebrow {
  display: block;
  font-family: 'Philosopher', sans-serif;
  font-size: 11px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: #999;
  margin-bottom: 14px;
}

.csn-heading {
  font-family: 'Philosopher', serif;
  font-size: clamp(28px, 3vw, 44px);
  font-weight: 400;
  color: var(--csn-dark);
  margin: 0 0 14px;
  line-height: 1.2;
}

.csn-subheading {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 17px;
  color: #888;
  margin: 0;
  line-height: 1.6;
}

/* ── Grid ── */
.csn-grid {
  display: grid;
  gap: 24px;
}

.csn-grid--1 { grid-template-columns: 1fr; }
.csn-grid--2 { grid-template-columns: repeat(2, 1fr); }
.csn-grid--3 { grid-template-columns: repeat(3, 1fr); }
.csn-grid--4 { grid-template-columns: repeat(4, 1fr); }

/* ── Card ── */
.csn-card {
  display: block;
  text-decoration: none;
  position: relative;
  overflow: hidden;
  background: #111;
}

.csn-card-img {
  position: relative;
  aspect-ratio: 3 / 4;
  overflow: hidden;
}

.csn-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  transition: transform 0.65s ease;
}

.csn-card-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #2a2018 0%, #1a1208 100%);
}

/* Dark gradient overlay for legibility */
.csn-card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(0, 0, 0, 0.72) 0%,
    rgba(0, 0, 0, 0.18) 50%,
    transparent 100%
  );
  transition: opacity 0.4s ease;
}

/* Card body — sits on top of image */
.csn-card-body {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 28px 24px;
  color: #fff;
  z-index: 2;
}

.csn-card-title {
  font-family: 'Philosopher', serif;
  font-size: clamp(20px, 2vw, 28px);
  font-weight: 400;
  margin: 0 0 6px;
  color: #fff;
  line-height: 1.2;
}

.csn-card-desc {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 14px;
  color: rgba(255, 255, 255, 0.75);
  margin: 0 0 16px;
  line-height: 1.5;
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: max-height 0.4s ease, opacity 0.35s ease;
}

.csn-card-cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: 'Philosopher', sans-serif;
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--csn-gold);
  border-bottom: 1px solid var(--csn-gold);
  padding-bottom: 2px;
  transition: gap 0.3s ease;
}

/* Hover effects */
.csn-card:hover .csn-card-img img {
  transform: scale(1.06);
}

.csn-card:hover .csn-card-overlay {
  opacity: 1.3;
}

.csn-card:hover .csn-card-desc {
  max-height: 80px;
  opacity: 1;
}

.csn-card:hover .csn-card-cta {
  gap: 13px;
}

/* Focus visible */
.csn-card:focus-visible {
  outline: 2px solid var(--csn-gold);
  outline-offset: 3px;
}

/* ── Responsive ── */
@media (max-width: 990px) {
  .csn-grid--4 { grid-template-columns: repeat(2, 1fr); }
  .csn-grid--3 { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 699px) {
  .csn-container { padding: 0 16px; }
  .csn-grid--4,
  .csn-grid--3,
  .csn-grid--2 { grid-template-columns: repeat(2, 1fr); }
  .csn-grid--1 { grid-template-columns: 1fr; }
  .csn-card-body { padding: 20px 16px; }
  .csn-card-title { font-size: 18px; }
  .csn-header { margin-bottom: 36px; }
}

@media (max-width: 479px) {
  .csn-grid--4,
  .csn-grid--3 { grid-template-columns: repeat(2, 1fr); }
  .csn-grid { gap: 14px; }
}

{% endstyle %}

{% schema %}
{
  "name": "Sub-Collection Cards",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "placeholder": "e.g. SHOP BY GENDER"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "placeholder": "e.g. Find Your Scent"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 64,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "subcollection",
      "name": "Sub-collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title override",
          "info": "Leave blank to use the collection title."
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description override",
          "info": "Leave blank to use the collection description."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image override",
          "info": "Leave blank to use the collection featured image."
        },
        {
          "type": "url",
          "id": "fallback_url",
          "label": "Fallback URL",
          "info": "Used if no collection is selected."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sub-Collection Cards",
      "blocks": [
        { "type": "subcollection" },
        { "type": "subcollection" },
        { "type": "subcollection" }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["collection", "index", "page"]
  }
}
{% endschema %}
