{%- liquid
  assign current_product = product
  assign related_collection = nil

  if collection != blank and collection.handle != 'all'
    assign related_collection = collection
  else
    comment
      Skip generic seasonal / occasion collections.
      Pick the collection with the most products as the primary one.
    endcomment
    assign skip_handles = 'all,autumn,summer,spring,winter,monsoon,daily,office,party,gym,sports,date,morning,evening,night' | split: ','
    assign best_count = 0

    for col in product.collections
      assign is_skip = false
      for sh in skip_handles
        if col.handle == sh
          assign is_skip = true
        endif
      endfor
      if is_skip == false and col.products_count > best_count
        assign best_count = col.products_count
        assign related_collection = col
      endif
    endfor

  endif

  assign product_limit = section.settings.product_limit | default: 8
-%}

{%- if related_collection != nil and related_collection.products_count > 1 -%}

<section class="related-products-section">
  <div class="container">

    <div class="section-header animate-on-scroll">
      <span class="section-label">{{ section.settings.label | default: 'You May Also Like' }}</span>
      <h2 class="section-title">{{ section.settings.title | default: 'Related Products' }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    {%- assign rp_badge_labels = 'Similar,You May Like,Related,Also Love,Try This,Explore,Pair With,Inspired By' | split: ',' -%}
    <div class="trending-grid">
      {%- assign shown_count = 0 -%}
      {%- for product in related_collection.products limit: 20 -%}
        {%- if product.handle == current_product.handle -%}{%- continue -%}{%- endif -%}
        {%- if shown_count >= product_limit -%}{%- break -%}{%- endif -%}
        {%- liquid
          assign first_variant = product.selected_or_first_available_variant
          assign badge_index   = shown_count | modulo: 8
          assign badge_label   = rp_badge_labels[badge_index]
        -%}

        <div class="tcard animate-on-scroll" data-delay="{{ shown_count | times: 60 }}">

          <a href="{{ product.url }}" class="tcard-full-link" aria-label="{{ product.title | escape }}"></a>

          <div class="tcard-media">
            <a href="{{ product.url }}" class="tcard-img-link" tabindex="-1" aria-hidden="true">
              {%- liquid
                if product.images.size > 2
                  assign primary_img = product.images[2]
                  assign hover_img   = product.images[1]
                elsif product.images.size > 1
                  assign primary_img = product.featured_image
                  assign hover_img   = product.images[1]
                else
                  assign primary_img = product.featured_image
                  assign hover_img   = nil
                endif
              -%}
              {%- if primary_img != blank -%}
                <img
                  class="tcard-img"
                  src="{{ primary_img | image_url: width: 480, format: 'webp' }}"
                  srcset="{{ primary_img | image_url: width: 320, format: 'webp' }} 320w,
                          {{ primary_img | image_url: width: 480, format: 'webp' }} 480w"
                  sizes="(max-width: 600px) 50vw, 25vw"
                  alt="{{ primary_img.alt | default: product.title | escape }}"
                  width="480" height="480" loading="lazy"
                >
                {%- if hover_img != blank -%}
                  <img
                    class="tcard-img tcard-img--hover"
                    src="{{ hover_img | image_url: width: 480, format: 'webp' }}"
                    alt="{{ hover_img.alt | default: product.title | escape }}"
                    width="480" height="480" loading="lazy"
                    aria-hidden="true"
                  >
                {%- endif -%}
              {%- else -%}
                {%- assign ph_idx = shown_count | modulo: 6 | plus: 1 -%}
                {{- 'product-' | append: ph_idx | placeholder_svg_tag: 'tcard-img' -}}
              {%- endif -%}
            </a>

            <span class="tcard-badge">{{ badge_label }}</span>

            <button
              class="tcard-wishlist product-card-wishlist"
              aria-label="Add {{ product.title | escape }} to wishlist"
              data-handle="{{ product.handle }}"
              data-title="{{ product.title | escape }}"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
              </svg>
            </button>

          </div>

          <div class="tcard-body">
            <a href="{{ product.url }}" class="tcard-name">{{ product.title }}</a>

            <div class="tcard-reviews">
              {%- liquid
                assign jdgm_badge = product.metafields.judgeme.badge
                assign show_real_badge = false
                if jdgm_badge != blank
                  unless jdgm_badge contains 'data-number-of-reviews="0'
                    assign show_real_badge = true
                  endunless
                endif
              -%}
              {%- if show_real_badge -%}
                {{ jdgm_badge }}
              {%- else -%}
                <div class="tcard-stars" role="img" aria-label="No reviews yet" style="--rating: 0%">
                  <span class="stars-filled" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
                  <span class="stars-empty" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
                </div>
                <span class="tcard-review-count">0 reviews</span>
              {%- endif -%}
            </div>

            <div class="tcard-price">
              <span class="tcard-price-current">{{ product.price | money }}</span>
              {%- if product.compare_at_price > product.price -%}
                <s class="tcard-price-compare">{{ product.compare_at_price | money }}</s>
              {%- endif -%}
            </div>

            {%- if product.available -%}
              <button
                class="tcard-quick-add product-quick-add-btn"
                type="button"
                data-variant-id="{{ first_variant.id }}"
                data-has-variants="{{ product.variants.size | minus: 1 | at_least: 0 }}"
                data-handle="{{ product.handle }}"
                data-title="{{ product.title | escape }}"
                data-product-url="{{ product.url }}"
                aria-label="Quick add {{ product.title | escape }}"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="14" height="14" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
                </svg>
                Quick Add
              </button>
            {%- else -%}
              <span class="tcard-soldout-btn">Sold Out</span>
            {%- endif -%}
          </div>

        </div>
        {%- assign shown_count = shown_count | plus: 1 -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.show_view_all -%}
      {%- assign view_all_url = section.settings.view_all_url -%}
      {%- if view_all_url == blank -%}
        {%- assign view_all_url = related_collection.url -%}
      {%- endif -%}
      <div class="section-cta animate-on-scroll">
        <a href="{{ view_all_url }}" class="btn btn-outline-gold">
          View All
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="15" height="15">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
          </svg>
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{%- endif -%}

{% style %}
  .btn-outline-gold{
    margin-bottom:10px;
  }
{% endstyle %}

{% schema %}
{
  "name": "Related Products",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "You May Also Like"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Related Products"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Max products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View All' button",
      "default": true
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View All -- link to collection",
      "info": "Set this to the exact collection URL you want. Leave blank to auto-detect."
    }
  ],
  "blocks": [{ "type": "@app" }],
  "presets": [
    {
      "name": "Related Products"
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
