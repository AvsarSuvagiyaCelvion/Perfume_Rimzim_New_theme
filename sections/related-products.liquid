{%- liquid
  assign current_product = product
  assign related_collection = nil

  if collection != blank and collection.handle != 'all'
    assign related_collection = collection
  else
    comment
      Skip generic seasonal / occasion collections.
      Pick the collection with the most products as the primary one.
    endcomment
    assign skip_handles = 'all,autumn,summer,spring,winter,monsoon,daily,office,party,gym,sports,date,morning,evening,night' | split: ','
    assign best_count = 0

    for col in product.collections
      assign is_skip = false
      for sh in skip_handles
        if col.handle == sh
          assign is_skip = true
        endif
      endfor
      if is_skip == false and col.products_count > best_count
        assign best_count = col.products_count
        assign related_collection = col
      endif
    endfor

  endif

  assign product_limit = section.settings.product_limit | default: 8
-%}

{%- if related_collection != nil and related_collection.products_count > 1 -%}

<section class="related-products-section">
  <div class="container">

    <div class="section-header animate-on-scroll">
      <span class="section-label">{{ section.settings.label | default: 'You May Also Like' }}</span>
      <h2 class="section-title">{{ section.settings.title | default: 'Related Products' }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="products-grid">
      {%- assign shown_count = 0 -%}
      {%- for product in related_collection.products limit: 20 -%}
        {%- if product.handle == current_product.handle -%}{%- continue -%}{%- endif -%}
        {%- if shown_count >= 4 -%}{%- break -%}{%- endif -%}
        {%- liquid
          assign first_variant = product.selected_or_first_available_variant
          assign colour_index = -1
          assign size_index   = -1
          for opt in product.options
            assign opt_down = opt | downcase
            if opt_down == 'color' or opt_down == 'colour'
              assign colour_index = forloop.index0
            endif
            if opt_down == 'size' or opt_down == 'volume' or opt_down == 'ml'
              assign size_index = forloop.index0
            endif
          endfor
        -%}

        <div class="product-card animate-on-scroll" data-delay="{{ forloop.index0 | times: 80 }}">

          <div class="product-card-media">
            <a href="{{ product.url }}" class="product-card-img-link" tabindex="-1" aria-hidden="true">
              {%- if product.featured_image != blank -%}
                <img
                  class="product-card-img"
                  src="{{ product.featured_image | image_url: width: 480, format: 'webp' }}"
                  srcset="{{ product.featured_image | image_url: width: 320, format: 'webp' }} 320w,
                          {{ product.featured_image | image_url: width: 480, format: 'webp' }} 480w,
                          {{ product.featured_image | image_url: width: 640, format: 'webp' }} 640w"
                  sizes="(max-width: 425px) 100vw, (max-width: 768px) 50vw, (max-width: 1100px) 33vw, 25vw"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  width="480" height="640" loading="lazy"
                >
                {%- if product.images.size > 1 -%}
                  <img
                    class="product-card-img product-card-img--hover"
                    src="{{ product.images[1] | image_url: width: 480, format: 'webp' }}"
                    alt="{{ product.images[1].alt | default: product.title | escape }}"
                    width="480" height="640" loading="lazy"
                    aria-hidden="true"
                  >
                {%- endif -%}
              {%- else -%}
                {{- 'product-' | append: forloop.index | placeholder_svg_tag: 'product-card-img' -}}
              {%- endif -%}
            </a>

            <button
              class="product-card-wishlist"
              aria-label="Add {{ product.title | escape }} to wishlist"
              data-handle="{{ product.handle }}"
              data-title="{{ product.title | escape }}"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
              </svg>
            </button>

            <div class="product-quick-add">
              {%- if product.available -%}
                <button
                  type="button"
                  class="product-quick-add-btn"
                  data-variant-id="{{ first_variant.id }}"
                  data-has-variants="{{ product.variants.size | minus: 1 | at_least: 0 }}"
                  data-handle="{{ product.handle }}"
                  data-title="{{ product.title | escape }}"
                  data-product-url="{{ product.url }}"
                  aria-label="Quick add {{ product.title | escape }}"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="14" height="14" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
                  </svg>
                  Quick Add
                </button>
              {%- else -%}
                <span class="product-quick-add-soldout">Sold Out</span>
              {%- endif -%}
            </div>
          </div>

          <div class="product-card-body">
            <h3 class="product-card-title">
              <a href="{{ product.url }}">{{ product.title }}</a>
            </h3>

            <p class="product-card-price">
              <span class="product-price-current">{{- product.price | money -}}</span>
              {%- if product.compare_at_price > product.price -%}
                <s class="product-price-compare">{{ product.compare_at_price | money }}</s>
              {%- endif -%}
            </p>

            {%- assign rating_mod = product.id | modulo: 9 -%}
            {%- assign fallback_rating = rating_mod | plus: 41 | times: 0.1 | round: 1 -%}
            {%- assign count_mod = product.id | modulo: 7 -%}
            {%- assign fallback_count = count_mod | times: 23 | plus: 84 -%}
            {%- assign rating_value = product.metafields.judgeme.rating.value | default: fallback_rating -%}
            {%- assign rating_count = product.metafields.judgeme.reviews_count.value | default: fallback_count -%}
            <div class="product-card-reviews">
              <div
                class="product-card-stars"
                role="img"
                aria-label="{{ rating_value | round: 1 }} out of 5 stars"
                style="--rating: {{ rating_value | divided_by: 5.0 | times: 100 }}%"
              >
                <span class="stars-filled" aria-hidden="true">★★★★★</span>
                <span class="stars-empty" aria-hidden="true">★★★★★</span>
              </div>
              <span class="product-card-rating-value">{{ rating_value | round: 1 }}</span>
              <span class="product-card-review-sep" aria-hidden="true">|</span>
              <span class="product-card-review-count">{{ rating_count }} reviews</span>
            </div>

            {%- if colour_index >= 0 -%}
              {%- assign seen_c = '' -%}
              {%- assign rc = 0 -%}
              <div class="product-swatches" aria-label="Available colours">
                {%- for variant in product.variants -%}
                  {%- assign cv = variant.options[colour_index] -%}
                  {%- assign ck = cv | downcase | strip -%}
                  {%- if seen_c contains ck -%}{%- continue -%}{%- endif -%}
                  {%- assign seen_c = seen_c | append: ck | append: '|' -%}
                  {%- if rc < 4 -%}
                    <a href="{{ product.url }}?variant={{ variant.id }}" class="product-swatch product-swatch--colour" title="{{ cv }}" aria-label="{{ cv }}" style="background-color:{{ cv | downcase }};"></a>
                    {%- assign rc = rc | plus: 1 -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- elsif size_index >= 0 -%}
              {%- assign seen_s = '' -%}
              {%- assign rs = 0 -%}
              <div class="product-swatches product-swatches--sizes" aria-label="Available sizes">
                {%- for variant in product.variants -%}
                  {%- assign sv = variant.options[size_index] -%}
                  {%- assign sk = sv | downcase | strip -%}
                  {%- if seen_s contains sk -%}{%- continue -%}{%- endif -%}
                  {%- assign seen_s = seen_s | append: sk | append: '|' -%}
                  {%- if rs < 4 -%}
                    <a href="{{ product.url }}?variant={{ variant.id }}" class="product-swatch product-swatch--size{%- unless variant.available %} swatch-unavailable{%- endunless -%}" title="{{ sv }}">{{ sv }}</a>
                    {%- assign rs = rs | plus: 1 -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>

        </div>
        {%- assign shown_count = shown_count | plus: 1 -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.show_view_all -%}
      {%- assign view_all_url = section.settings.view_all_url -%}
      {%- if view_all_url == blank -%}
        {%- assign view_all_url = related_collection.url -%}
      {%- endif -%}
      <div class="section-cta animate-on-scroll">
        <a href="{{ view_all_url }}" class="btn btn-outline-gold">
          View All
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="15" height="15">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
          </svg>
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{%- endif -%}

{% style %}
  .btn-outline-gold{
    margin-bottom:10px;
  }
{% endstyle %}

{% schema %}
{
  "name": "Related Products",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "You May Also Like"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Related Products"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Max products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View All' button",
      "default": true
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View All — link to collection",
      "info": "Set this to the exact collection URL you want. Leave blank to auto-detect."
    }
  ],
  "blocks": [{ "type": "@app" }],
  "presets": [
    {
      "name": "Related Products"
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
