<header class="site-header" id="SiteHeader" role="banner">
  <div class="">
    <div class="header-inner">

      {%- comment -%} ── Logo ── {%- endcomment -%}
      <div class="header-logo">
        <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
          {%- if section.settings.logo != blank -%}
            <img
              src="{{ section.settings.logo | image_url: width: 480 }}"
              srcset="{{ section.settings.logo | image_url: width: 240 }} 240w,
                      {{ section.settings.logo | image_url: width: 480 }} 480w"
              sizes="240px"
              alt="{{ section.settings.logo.alt | default: shop.name }}"
              width="{{ section.settings.logo_width | default: 160 }}"
              height="56"
              loading="eager"
              style="height: {{ section.settings.logo_height | default: 56 }}px; width: auto;"
            >
          {%- else -%}
            <span class="logo-text">
              {{ section.settings.brand_name | default: shop.name }}
              <span class="logo-sub">{{ section.settings.tagline | default: 'Luxury Perfumes' }}</span>
            </span>
          {%- endif -%}
        </a>
      </div>

      {%- comment -%} ── Desktop Navigation ── {%- endcomment -%}
      <nav class="header-nav" role="navigation" aria-label="Main navigation">
        {%- for link in linklists[section.settings.menu].links -%}

          {%- if link.links.size > 0 -%}
            {%- comment -%} Parent with dropdown {%- endcomment -%}
            <div class="nav-item has-dropdown">
              <a
                href="{{ link.url }}"
                class="nav-link"
                aria-haspopup="true"
                aria-expanded="false"
                {%- if link.active %} aria-current="page"{% endif -%}
              >
                {{- link.title -}}
                <svg class="nav-chevron" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="12" height="12" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
                </svg>
              </a>

              <div class="nav-dropdown" role="list">
                <div class="nav-dropdown-inner">
                  {%- for child_link in link.links -%}
                    <a
                      href="{{ child_link.url }}"
                      class="nav-dropdown-link"
                      role="listitem"
                      {%- if child_link.active %} aria-current="page"{% endif -%}
                    >
                      <span class="nav-dropdown-link-dot" aria-hidden="true"></span>
                      {{- child_link.title -}}
                    </a>
                  {%- endfor -%}
                </div>
              </div>
            </div>

          {%- else -%}
            {%- comment -%} Regular link {%- endcomment -%}
            <a
              href="{{ link.url }}"
              class="nav-link"
              {%- if link.active %} aria-current="page"{% endif -%}
            >{{ link.title }}</a>
          {%- endif -%}

        {%- else -%}
          <a href="{{ routes.root_url }}" class="nav-link">Home</a>
          <a href="{{ routes.collections_url }}" class="nav-link">Collections</a>
          <a href="{{ routes.collections_url }}/new-arrivals" class="nav-link">New Arrivals</a>
          <a href="/pages/about" class="nav-link">About</a>
          <a href="/pages/contact" class="nav-link">Contact</a>
        {%- endfor -%}
      </nav>

      {%- comment -%} ── Action Icons ── {%- endcomment -%}
      <div class="header-actions">

        {%- comment -%} Search {%- endcomment -%}
        <button
          type="button"
          class="header-icon-btn search-toggle-btn"
          id="SearchToggle"
          aria-label="Open search"
          aria-expanded="false"
          aria-controls="SearchDrawer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
          </svg>
        </button>

        {%- comment -%} Wishlist {%- endcomment -%}
        <a href="/pages/wishlist" class="header-icon-btn wishlist-btn" aria-label="Wishlist" style="position:relative;">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
          </svg>
          <span class="wishlist-count" aria-live="polite" style="display:none;"></span>
        </a>

        {%- comment -%} Account {%- endcomment -%}
        <a
          href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
          class="header-icon-btn"
          aria-label="{%- if customer -%}My account{%- else -%}Log in{%- endif -%}"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
          </svg>
        </a>

        {%- comment -%} Cart {%- endcomment -%}
        <a href="{{ routes.cart_url }}" class="header-icon-btn" aria-label="Cart ({{ cart.item_count }} items)">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm5.625 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
          </svg>
          <span
            class="cart-count"
            aria-live="polite"
            style="display: {%- if cart.item_count > 0 -%}flex{%- else -%}none{%- endif -%};"
          >{{ cart.item_count }}</span>
        </a>

        {%- comment -%} Mobile hamburger {%- endcomment -%}
        <button
          class="mobile-menu-toggle"
          aria-label="Open navigation"
          aria-expanded="false"
          aria-controls="MobileNav"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>

      </div>
    </div>
  </div>
</header>

{%- comment -%} ── Search Drawer ── {%- endcomment -%}
<div class="search-drawer" id="SearchDrawer" aria-hidden="true" role="dialog" aria-label="Search" inert>
  <div class="search-drawer-inner">
    <form action="{{ routes.search_url }}" method="get" class="search-drawer-form" role="search">
      <input type="hidden" name="type" value="product">
      <div class="search-drawer-field">
        <svg class="search-drawer-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
        </svg>
        <input
          type="search"
          name="q"
          id="SearchInput"
          class="search-drawer-input"
          placeholder="Search for fragrances, notes, brands…"
          autocomplete="off"
          autocorrect="off"
          spellcheck="false"
          aria-label="Search"
        >
        <button type="button" class="search-drawer-clear" id="SearchClear" aria-label="Clear search" hidden>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="16" height="16">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <button type="submit" class="btn btn-primary search-drawer-submit">Search</button>
    </form>

    <div class="search-results" id="SearchResults" aria-live="polite" hidden></div>
  </div>

  <button type="button" class="search-drawer-close" id="SearchClose" aria-label="Close search">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
    </svg>
    Close
  </button>
</div>
<div class="search-backdrop" id="SearchBackdrop"></div>

{%- comment -%} ── Mobile Navigation Drawer ── {%- endcomment -%}
<nav id="MobileNav" class="mobile-nav" aria-label="Mobile navigation">
  {%- for link in linklists[section.settings.menu].links -%}

    {%- if link.links.size > 0 -%}
      {%- comment -%} Accordion item {%- endcomment -%}
      <div class="mobile-nav-accordion">
        <div class="mobile-nav-accordion-row">
          <a href="{{ link.url }}" class="mobile-nav-link">{{ link.title }}</a>
          <button
            class="mobile-nav-accordion-toggle"
            aria-expanded="false"
            aria-label="Toggle {{ link.title }} submenu"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="16" height="16" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
            </svg>
          </button>
        </div>
        <div class="mobile-nav-submenu" hidden>
          {%- for child_link in link.links -%}
            <a
              href="{{ child_link.url }}"
              class="mobile-nav-submenu-link"
              {%- if child_link.active %} aria-current="page"{% endif -%}
            >{{ child_link.title }}</a>
          {%- endfor -%}
        </div>
      </div>

    {%- else -%}
      <a href="{{ link.url }}" class="mobile-nav-link">{{ link.title }}</a>
    {%- endif -%}

  {%- else -%}
    <a href="{{ routes.root_url }}" class="mobile-nav-link">Home</a>
    <a href="{{ routes.collections_url }}" class="mobile-nav-link">Collections</a>
    <a href="{{ routes.collections_url }}/new-arrivals" class="mobile-nav-link">New Arrivals</a>
    <a href="/pages/about" class="mobile-nav-link">About</a>
    <a href="/pages/contact" class="mobile-nav-link">Contact</a>
  {%- endfor -%}
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height (px)",
      "min": 32,
      "max": 96,
      "step": 4,
      "default": 56
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "LUMIÈRE"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Brand tagline",
      "default": "Luxury Perfumes"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
