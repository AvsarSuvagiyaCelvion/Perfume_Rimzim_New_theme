{%- liquid
  assign search_terms = search.terms | escape
  assign results      = search.results
  assign total        = search.results_count
-%}

<div class="search-page">

  {%- comment -%} ── Hero bar ── {%- endcomment -%}
  <div class="search-page-hero">
    <div class="container">
      <form action="/search" method="get" class="search-page-form" role="search">
        <input type="hidden" name="type" value="product">
        <div class="search-page-field">
          <svg class="search-page-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
          </svg>
          <input
            type="search"
            name="q"
            class="search-page-input"
            value="{{ search_terms }}"
            placeholder="Search fragrances, notes, brands…"
            autocomplete="off"
            aria-label="Search"
            autofocus
          >
        </div>
        <button type="submit" class="btn btn-primary search-page-submit">Search</button>
      </form>

      {%- if search_terms != blank -%}
        <p class="search-page-meta">
          {%- if total > 0 -%}
            <span>{{ total }} result{{ total | pluralize: '', 's' }} for</span>
            <strong>"{{ search_terms }}"</strong>
          {%- else -%}
            <span>No results for</span>
            <strong>"{{ search_terms }}"</strong>
          {%- endif -%}
        </p>
      {%- endif -%}
    </div>
  </div>

  <div class="container search-page-body">

    {%- if search_terms == blank -%}

      <div class="search-empty-state">
        <div class="search-empty-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
          </svg>
        </div>
        <h2 class="search-empty-heading">What are you looking for?</h2>
        <p class="search-empty-sub">Try searching for a fragrance name, note, or collection.</p>
      </div>

    {%- elsif total == 0 -%}

      <div class="search-empty-state">
        <div class="search-empty-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.182 16.318A4.486 4.486 0 0012.016 15a4.486 4.486 0 00-3.198 1.318M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z"/>
          </svg>
        </div>
        <h2 class="search-empty-heading">No results found</h2>
        <p class="search-empty-sub">Try a different keyword or browse our collections below.</p>
        <a href="/collections/all" class="btn btn-primary" style="margin-top:24px;">Browse All Products</a>
      </div>

    {%- else -%}

      <div class="search-results-grid">
        {%- for item in results -%}
          {%- if item.object_type == 'product' -%}
            {%- liquid
              assign item_price = item.price
              assign compare    = item.compare_at_price
            -%}

            <a href="{{ item.url }}" class="search-product-card">
              <div class="search-product-media">
                {%- if item.featured_image != blank -%}
                  <img
                    src="{{ item.featured_image | image_url: width: 480 }}"
                    alt="{{ item.featured_image.alt | default: item.title | escape }}"
                    class="search-product-img"
                    width="240" height="320" loading="lazy"
                  >
                {%- else -%}
                  {{- 'product-1' | placeholder_svg_tag: 'search-product-img' -}}
                {%- endif -%}

              </div>

              <div class="search-product-info">
                {%- if item.vendor != blank -%}
                  <p class="search-product-vendor">{{ item.vendor }}</p>
                {%- endif -%}
                <h3 class="search-product-title">{{ item.title }}</h3>
                <p class="search-product-price">
                  {%- if compare > item_price -%}
                    <s class="search-price-compare">{{ compare | money }}</s>
                  {%- endif -%}
                  <span class="search-price-current {%- if compare > item_price %} price-sale{%- endif -%}">
                    {{- item_price | money -}}
                  </span>
                </p>
              </div>
            </a>

          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div class="search-pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="btn btn-outline">← Previous</a>
          {%- endif -%}
          <span class="search-pagination-info">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="btn btn-outline">Next →</a>
          {%- endif -%}
        </div>
      {%- endif -%}

    {%- endif -%}

  </div>
</div>

{% style %}

/* ── Search Page ── */
.search-page {
  min-height: 70vh;
  background: var(--color-bg);
}

/* Hero bar */
.search-page-hero {
  background: var(--color-dark);
  padding: 48px 0 40px;
}
.search-page-form {
  display: flex;
  gap: 12px;
  align-items: center;
  max-width: 720px;
}
.search-page-field {
  position: relative;
  flex: 1;
}
.search-page-icon {
  position: absolute;
  left: 18px;
  top: 50%; transform: translateY(-50%);
  width: 20px; height: 20px;
  color: rgba(255,255,255,0.35);
  pointer-events: none;
}
.search-page-input {
  width: 100%;
  height: 54px;
  padding: 0 20px 0 52px;
  background: rgba(255,255,255,0.08);
  border: 1.5px solid rgba(255,255,255,0.15);
  border-radius: var(--radius-full);
  font-family: var(--font-heading);
  font-size: 1rem;
  color: #fff;
  transition: border-color 0.2s, background 0.2s;
  -webkit-appearance: none;
  appearance: none;
}
.search-page-input::placeholder { color: rgba(255,255,255,0.3); font-style: italic; }
.search-page-input:focus {
  outline: none;
  border-color: var(--color-primary);
  background: rgba(255,255,255,0.12);
}
.search-page-input::-webkit-search-cancel-button { display: none; }
.search-page-submit {
  height: 54px;
  padding: 0 28px;
  border-radius: var(--radius-full);
  white-space: nowrap;
  flex-shrink: 0;
  font-size: 0.8rem;
  letter-spacing: 0.1em;
}
.search-page-meta {
  margin-top: 20px;
  font-size: 0.9rem;
  color: rgba(255,255,255,0.5);
  max-width: 720px;
}
.search-page-meta strong {
  color: #fff;
  font-weight: 600;
  margin-left: 4px;
}

/* Body */
.search-page-body {
  padding: 56px 0 80px;
}

/* Empty / no results */
.search-empty-state {
  text-align: center;
  padding: 60px 20px;
}
.search-empty-icon {
  width: 64px; height: 64px;
  margin: 0 auto 24px;
  color: var(--color-border);
}
.search-empty-icon svg { width: 100%; height: 100%; }
.search-empty-heading {
  font-family: var(--font-heading);
  font-size: 1.5rem;
  font-weight: 400;
  color: var(--color-text);
  margin: 0 0 12px;
}
.search-empty-sub {
  font-size: 0.9rem;
  color: var(--color-text-muted);
  margin: 0;
}

/* Results grid */
.search-results-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 28px;
}

/* Product card */
.search-product-card {
  text-decoration: none;
  display: block;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--color-white);
  position: relative;
  transition: transform 0.35s var(--ease-out), box-shadow 0.35s ease;
}
.search-product-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-xl);
}
.search-product-media {
  position: relative;
  aspect-ratio: 3/4;
  overflow: hidden;
  background: var(--color-bg-alt);
}
.search-product-img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.6s ease;
}
.search-product-card:hover .search-product-img { transform: scale(1.06); }
.search-product-badge {
  position: absolute;
  top: 12px; left: 12px;
  background: #C0392B;
  color: #fff;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: var(--radius-full);
}
.search-product-info {
  padding: 16px 18px 20px;
  text-align: center;
}
.search-product-vendor {
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-text-muted);
  margin: 0 0 6px;
}
.search-product-title {
  font-family: var(--font-heading);
  font-size: 0.95rem;
  font-weight: 400;
  color: var(--color-text);
  margin: 0 0 10px;
  line-height: 1.3;
}
.search-product-price {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-size: 0.9rem;
}
.search-price-compare {
  color: var(--color-text-muted);
  font-size: 0.8rem;
  text-decoration: line-through;
}
.search-price-current { font-weight: 600; color: var(--color-text); }
.search-price-current.price-sale { color: #C0392B; }

/* Pagination */
.search-pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
  margin-top: 56px;
  padding-top: 32px;
  border-top: 1px solid var(--color-border);
}
.search-pagination-info {
  font-size: 0.85rem;
  color: var(--color-text-muted);
}

/* Responsive */
@media (max-width: 1024px) {
  .search-results-grid { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 768px) {
  .search-page-form { flex-wrap: wrap; }
  .search-page-field { flex: 1 1 100%; }
  .search-page-submit { width: 100%; justify-content: center; }
  .search-results-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
}
@media (max-width: 480px) {
  .search-results-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
  .search-product-info { padding: 12px; }
}

{% endstyle %}

{% schema %}
{
  "name": "Search Results",
  "settings": []
}
{% endschema %}
