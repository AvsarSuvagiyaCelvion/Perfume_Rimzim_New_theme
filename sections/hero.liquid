<section class="hero-section" id="HeroSection">
  <div class="container">
    <div class="hero-inner">

      {%- comment -%} ── Content Side ── {%- endcomment -%}
      <div class="hero-content animate-on-scroll">

        <p class="hero-eyebrow">
          {{ section.settings.eyebrow | default: 'New Collection' }}
        </p>

        <h1 class="hero-title">
          {{- section.settings.heading_before | default: 'Discover Your' -}}
          {%- unless section.settings.heading_italic == blank -%}
            <em> {{ section.settings.heading_italic }} </em>
          {%- endunless -%}
          {{- section.settings.heading_after | default: 'Scent' -}}
        </h1>

        <p class="hero-description">
          {{ section.settings.description | default: 'Luxury fragrances crafted for every mood and season. Elevate your presence with our exclusive perfume collections.' }}
        </p>

        <div class="hero-actions">
          <a href="{{ section.settings.button_url | default: '/collections/all' }}" class="btn btn-primary">
            {{ section.settings.button_text | default: 'Shop Now' }}
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="15" height="15">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
          {%- if section.settings.secondary_button_text != blank -%}
            <a href="{{ section.settings.secondary_button_url | default: '/collections' }}" class="btn btn-outline">
              {{ section.settings.secondary_button_text }}
            </a>
          {%- endif -%}
        </div>

        <div class="hero-divider"></div>

        <div class="hero-stats">
          <div>
            <span class="hero-stat-value">{{ section.settings.stat1_value | default: '500+' }}</span>
            <span class="hero-stat-label">{{ section.settings.stat1_label | default: 'Fragrances' }}</span>
          </div>
          <div>
            <span class="hero-stat-value">{{ section.settings.stat2_value | default: '50K+' }}</span>
            <span class="hero-stat-label">{{ section.settings.stat2_label | default: 'Happy Clients' }}</span>
          </div>
          <div>
            <span class="hero-stat-value">{{ section.settings.stat3_value | default: '15+' }}</span>
            <span class="hero-stat-label">{{ section.settings.stat3_label | default: 'Collections' }}</span>
          </div>
        </div>

      </div>

      {%- comment -%} ── Visual Side ── {%- endcomment -%}
      <div class="hero-visual animate-on-scroll" data-delay="150">

        <div class="hero-bg-orb"></div>

        <div class="hero-img-frame">
          {%- if section.settings.hero_image != blank -%}
            <img
              src="{{ section.settings.hero_image | image_url: width: 600 }}"
              srcset="{{ section.settings.hero_image | image_url: width: 400 }} 400w,
                      {{ section.settings.hero_image | image_url: width: 600 }} 600w,
                      {{ section.settings.hero_image | image_url: width: 900 }} 900w"
              sizes="(max-width: 768px) 90vw, 45vw"
              alt="{{ section.settings.hero_image.alt | default: 'Luxury perfume' }}"
              width="440" height="587" loading="eager"
            >
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'hero-placeholder-svg' }}
          {%- endif -%}
        </div>

        {%- comment -%} Floating trust badge {%- endcomment -%}
        <div class="hero-badge" aria-hidden="true">
          <div class="hero-badge-icon">✨</div>
          <div>
            <span class="hero-badge-strong">{{ section.settings.badge_title | default: 'Premium Quality' }}</span>
            <span class="hero-badge-muted">{{ section.settings.badge_subtitle | default: '100% Authentic' }}</span>
          </div>
        </div>

      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "New Collection"
    },
    {
      "type": "text",
      "id": "heading_before",
      "label": "Heading — Part 1",
      "default": "Discover Your"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading — Italic word",
      "default": "Signature"
    },
    {
      "type": "text",
      "id": "heading_after",
      "label": "Heading — Part 3",
      "default": "Scent"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Luxury fragrances crafted for every mood and season. Elevate your presence with our exclusive perfume collections."
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Button text",
      "default": "Explore All"
    },
    {
      "type": "url",
      "id": "secondary_button_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Stats"
    },
    {
      "type": "text",
      "id": "stat1_value",
      "label": "Stat 1 value",
      "default": "500+"
    },
    {
      "type": "text",
      "id": "stat1_label",
      "label": "Stat 1 label",
      "default": "Fragrances"
    },
    {
      "type": "text",
      "id": "stat2_value",
      "label": "Stat 2 value",
      "default": "50K+"
    },
    {
      "type": "text",
      "id": "stat2_label",
      "label": "Stat 2 label",
      "default": "Happy Clients"
    },
    {
      "type": "text",
      "id": "stat3_value",
      "label": "Stat 3 value",
      "default": "15+"
    },
    {
      "type": "text",
      "id": "stat3_label",
      "label": "Stat 3 label",
      "default": "Collections"
    },
    {
      "type": "header",
      "content": "Image & Badge"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "badge_title",
      "label": "Badge title",
      "default": "Premium Quality"
    },
    {
      "type": "text",
      "id": "badge_subtitle",
      "label": "Badge subtitle",
      "default": "100% Authentic"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
