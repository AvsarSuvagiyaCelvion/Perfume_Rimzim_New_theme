{%- assign has_bg = false -%}
{%- if section.settings.hero_image != blank -%}
  {%- assign has_bg = true -%}
{%- endif -%}
{%- assign img_pos        = section.settings.image_position        | default: 'center center' -%}
{%- assign img_pos_mobile = section.settings.image_position_mobile | default: img_pos -%}

<section
  class="hero-section{% if has_bg %} hero-section--has-bg{% endif %}"
  id="HeroSection"
  style="--hero-img-pos: {{ img_pos }}; --hero-img-pos-mobile: {{ img_pos_mobile }}"
>

  {%- comment -%} ── Full-bleed background image ── {%- endcomment -%}
  {%- if has_bg -%}
    <div class="hero-bg" aria-hidden="true">
      <picture>

        {%- comment -%} ── MOBILE ≤ 767px ── {%- endcomment -%}
        {%- if section.settings.hero_mobile_image != blank -%}
          {%- assign mob = section.settings.hero_mobile_image -%}
          <source
            media="(max-width: 767px)"
            srcset="{{ mob | image_url: width: 400,  format: 'webp' }} 400w,
                    {{ mob | image_url: width: 600,  format: 'webp' }} 600w,
                    {{ mob | image_url: width: 800,  format: 'webp' }} 800w,
                    {{ mob | image_url: width: 1000, format: 'webp' }} 1000w"
            sizes="100vw"
          >
        {%- else -%}
          <source
            media="(max-width: 767px)"
            srcset="{{ section.settings.hero_image | image_url: width: 400,  format: 'webp' }} 400w,
                    {{ section.settings.hero_image | image_url: width: 600,  format: 'webp' }} 600w,
                    {{ section.settings.hero_image | image_url: width: 800,  format: 'webp' }} 800w,
                    {{ section.settings.hero_image | image_url: width: 1000, format: 'webp' }} 1000w"
            sizes="100vw"
          >
        {%- endif -%}

        {%- comment -%} ── TABLET 768px – 1199px ── {%- endcomment -%}
        <source
          media="(min-width: 768px) and (max-width: 1199px)"
          srcset="{{ section.settings.hero_image | image_url: width: 800,  format: 'webp' }} 800w,
                  {{ section.settings.hero_image | image_url: width: 1200, format: 'webp' }} 1200w,
                  {{ section.settings.hero_image | image_url: width: 1600, format: 'webp' }} 1600w"
          sizes="100vw"
        >

        {%- comment -%} ── DESKTOP ≥ 1200px ── {%- endcomment -%}
        <source
          media="(min-width: 1200px)"
          srcset="{{ section.settings.hero_image | image_url: width: 1200, format: 'webp' }} 1200w,
                  {{ section.settings.hero_image | image_url: width: 1600, format: 'webp' }} 1600w,
                  {{ section.settings.hero_image | image_url: width: 2000, format: 'webp' }} 2000w,
                  {{ section.settings.hero_image | image_url: width: 2400, format: 'webp' }} 2400w"
          sizes="100vw"
        >

        {%- comment -%} ── FALLBACK <img> for browsers without <picture> support ── {%- endcomment -%}
        <img
          class="hero-bg-img"
          src="{{ section.settings.hero_image | image_url: width: 1600 }}"
          srcset="{{ section.settings.hero_image | image_url: width: 800  }} 800w,
                  {{ section.settings.hero_image | image_url: width: 1200 }} 1200w,
                  {{ section.settings.hero_image | image_url: width: 1600 }} 1600w,
                  {{ section.settings.hero_image | image_url: width: 2000 }} 2000w"
          sizes="100vw"
          alt="{{ section.settings.hero_image.alt | default: '' }}"
          width="1600" height="900"
          loading="eager"
          fetchpriority="high"
        >
      </picture>
    </div>
    <div class="hero-overlay" aria-hidden="true"></div>
  {%- else -%}
    {%- comment -%} Fallback decorative orb when no image set {%- endcomment -%}
    <div class="hero-fallback-orb" aria-hidden="true"></div>
  {%- endif -%}

  <div class="container">
    <div class="hero-inner">

      {%- comment -%} ── Content ── {%- endcomment -%}
      <div class="hero-content">

        <p class="hero-eyebrow t-reveal t-reveal--left" style="--td:0ms">
          {{ section.settings.eyebrow | default: 'New Collection' }}
        </p>

        <h1 class="hero-title">
          <span class="t-word" style="--td:200ms">
            {{- section.settings.heading_before | default: 'Discover Your' -}}
          </span>
          {%- unless section.settings.heading_italic == blank -%}
            <em class="t-word t-word--gold" style="--td:400ms">
              {{- ' ' -}}{{ section.settings.heading_italic }}{{- ' ' -}}
            </em>
          {%- endunless -%}
          <span class="t-word" style="--td:600ms">
            {{- section.settings.heading_after | default: 'Scent' -}}
          </span>
        </h1>

        <p class="hero-description t-reveal" style="--td:850ms">
          {{ section.settings.description | default: 'Luxury fragrances crafted for every mood and season. Elevate your presence with our exclusive perfume collections.' }}
        </p>

        <div class="hero-actions t-reveal t-reveal--scale" style="--td:1050ms">
          <a href="{{ section.settings.button_url | default: '/collections/all' }}" class="btn btn-primary">
            {{ section.settings.button_text | default: 'Shop Now' }}
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="15" height="15" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
          {%- if section.settings.secondary_button_text != blank -%}
            <a href="{{ section.settings.secondary_button_url | default: '/collections' }}" class="btn btn-outline-white">
              {{ section.settings.secondary_button_text }}
            </a>
          {%- endif -%}
        </div>


      </div>


    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "New Collection"
    },
    {
      "type": "text",
      "id": "heading_before",
      "label": "Heading — Part 1",
      "default": "Discover Your"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "Heading — Italic word",
      "default": "Signature"
    },
    {
      "type": "text",
      "id": "heading_after",
      "label": "Heading — Part 3",
      "default": "Scent"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Luxury fragrances crafted for every mood and season. Elevate your presence with our exclusive perfume collections."
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Button text",
      "default": "Explore All"
    },
    {
      "type": "url",
      "id": "secondary_button_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Stats"
    },
    {
      "type": "text",
      "id": "stat1_value",
      "label": "Stat 1 value",
      "default": "500+"
    },
    {
      "type": "text",
      "id": "stat1_label",
      "label": "Stat 1 label",
      "default": "Fragrances"
    },
    {
      "type": "text",
      "id": "stat2_value",
      "label": "Stat 2 value",
      "default": "50K+"
    },
    {
      "type": "text",
      "id": "stat2_label",
      "label": "Stat 2 label",
      "default": "Happy Clients"
    },
    {
      "type": "text",
      "id": "stat3_value",
      "label": "Stat 3 value",
      "default": "15+"
    },
    {
      "type": "text",
      "id": "stat3_label",
      "label": "Stat 3 label",
      "default": "Collections"
    },
    {
      "type": "header",
      "content": "Background Image & Badge"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Background image — Desktop (landscape, 16:9 recommended)"
    },
    {
      "type": "image_picker",
      "id": "hero_mobile_image",
      "label": "Background image — Mobile (portrait, 9:16 recommended)"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image focal point — Desktop",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top",    "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center",   "label": "Left" },
        { "value": "right center",  "label": "Right" }
      ],
      "default": "center center"
    },
    {
      "type": "select",
      "id": "image_position_mobile",
      "label": "Image focal point — Mobile",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top",    "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center",   "label": "Left" },
        { "value": "right center",  "label": "Right" }
      ],
      "default": "center center"
    },
    {
      "type": "text",
      "id": "badge_title",
      "label": "Badge title",
      "default": "Premium Quality"
    },
    {
      "type": "text",
      "id": "badge_subtitle",
      "label": "Badge subtitle",
      "default": "100% Authentic"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
