{%- liquid
  assign has_bottle = false
  if section.settings.bottle_image != blank
    assign has_bottle = true
  endif
-%}

<section
  class="pb-section"
  id="ParallaxBottle-{{ section.id }}"
  style="--pb-bg: {{ section.settings.bg_color }};"
>
  <div class="container pb-inner">

    {%- comment -%} ── Left: text content ── {%- endcomment -%}
    <div class="pb-content">

      {%- if section.settings.eyebrow != blank -%}
        <p class="pb-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="pb-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <p class="pb-subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}

      {%- if section.settings.btn_label != blank -%}
        <a
          href="{{ section.settings.btn_url | default: '#' }}"
          class="btn btn-primary pb-cta"
        >
          {{ section.settings.btn_label }}
        </a>
      {%- endif -%}

    </div>

    {%- comment -%} ── Right: 3D bottle ── {%- endcomment -%}
    <div class="pb-stage" id="PbStage-{{ section.id }}" aria-hidden="true">

      <div class="pb-glow"></div>

      <div class="pb-card" id="PbCard-{{ section.id }}">
        {%- if has_bottle -%}
          <img
            class="pb-bottle-img"
            src="{{ section.settings.bottle_image | image_url: width: 600, format: 'webp' }}"
            srcset="{{ section.settings.bottle_image | image_url: width: 400, format: 'webp' }} 400w,
                    {{ section.settings.bottle_image | image_url: width: 600, format: 'webp' }} 600w,
                    {{ section.settings.bottle_image | image_url: width: 800, format: 'webp' }} 800w"
            sizes="(max-width: 768px) 60vw, 400px"
            alt="{{ section.settings.bottle_image.alt | default: section.settings.heading | escape }}"
            width="600"
            height="800"
            loading="lazy"
            draggable="false"
          >
        {%- else -%}
          <div class="pb-placeholder">
            <svg viewBox="0 0 120 200" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect x="35" y="10" width="50" height="8" rx="4" fill="currentColor" opacity=".3"/>
              <rect x="40" y="18" width="40" height="12" rx="4" fill="currentColor" opacity=".4"/>
              <rect x="20" y="30" width="80" height="140" rx="12" fill="currentColor" opacity=".15"/>
              <rect x="28" y="38" width="64" height="124" rx="8" fill="currentColor" opacity=".1"/>
              <text x="60" y="115" text-anchor="middle" fill="currentColor" opacity=".4" font-size="10">Upload image</text>
            </svg>
          </div>
        {%- endif -%}

        {%- comment -%} Reflection shine overlay ── purely decorative {%- endcomment -%}
        <div class="pb-shine" aria-hidden="true"></div>
      </div>

    </div>

  </div>
</section>

<script>
(function () {
  'use strict';

  var stage = document.getElementById('PbStage-{{ section.id }}');
  var card  = document.getElementById('PbCard-{{ section.id }}');
  if (!stage || !card) return;

  /* Skip on touch devices — use float animation instead */
  if (window.matchMedia('(hover: none)').matches) return;

  var TILT_MAX  = 18;   /* max degrees of rotation */
  var LIFT      = 18;   /* px translateZ on hover */
  var raf       = null;
  var targetX   = 0, targetY = 0;
  var currentX  = 0, currentY = 0;
  var hovering  = false;

  function lerp(a, b, t) { return a + (b - a) * t; }

  function tick() {
    currentX = lerp(currentX, targetX, 0.1);
    currentY = lerp(currentY, targetY, 0.1);

    card.style.transform =
      'perspective(800px) ' +
      'rotateY(' + currentX + 'deg) ' +
      'rotateX(' + (-currentY) + 'deg) ' +
      'translateZ(' + (hovering ? LIFT : 0) + 'px)';

    /* Update shine position */
    var shine = card.querySelector('.pb-shine');
    if (shine) {
      shine.style.background =
        'radial-gradient(circle at ' +
        (50 + currentX * 1.5) + '% ' +
        (50 - currentY * 1.5) + '%, ' +
        'rgba(255,255,255,0.22) 0%, transparent 65%)';
    }

    if (hovering || Math.abs(currentX) > 0.05 || Math.abs(currentY) > 0.05) {
      raf = requestAnimationFrame(tick);
    } else {
      raf = null;
    }
  }

  stage.addEventListener('mousemove', function (e) {
    var rect    = stage.getBoundingClientRect();
    var relX    = (e.clientX - rect.left) / rect.width  - 0.5;
    var relY    = (e.clientY - rect.top)  / rect.height - 0.5;
    targetX     = relX * TILT_MAX * 2;
    targetY     = relY * TILT_MAX * 2;
    hovering    = true;
    if (!raf) raf = requestAnimationFrame(tick);
  });

  stage.addEventListener('mouseleave', function () {
    targetX  = 0;
    targetY  = 0;
    hovering = false;
    if (!raf) raf = requestAnimationFrame(tick);
  });
})();
</script>

{% schema %}
{
  "name": "Parallax Bottle",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#111111"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "NEW ARRIVAL"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Crafted for the Bold"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "A fragrance that moves with you. Hover to explore the bottle."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "bottle_image",
      "label": "Bottle image (PNG with transparent background recommended)"
    }
  ],
  "presets": [
    {
      "name": "Parallax Bottle",
      "category": "Image"
    }
  ],
  "blocks": [
    { "type": "@app" }
  ]
}
{% endschema %}
