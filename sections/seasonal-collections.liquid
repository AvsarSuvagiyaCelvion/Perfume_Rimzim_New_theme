<section class="seasonal-v2-section" id="SeasonalCollectionsV2">
  <div class="container">

    <div class="section-header-v2 animate-on-scroll">
      <span class="eyebrow">EXPLORE</span>
      <h2 class="section-title">{{ section.settings.title | default: 'Shop by Season' }}</h2>
      <div class="accent-line"></div>
      {%- if section.settings.subtitle != blank -%}
          <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="seasonal-editorial-grid">
    {%- for block in section.blocks -%}
      <div class="seasonal-card-wrapper card-size-{{ forloop.index }} animate-on-scroll" data-delay="{{ forloop.index0 | times: 150 }}">
        
        {%- if block.settings.mood_text != blank -%}
          <span class="floating-mood-text">{{ block.settings.mood_text }}</span>
        {%- endif -%}

        <a href="{{ block.settings.collection_url | default: '/collections/all' }}" class="seasonal-card-v2" {{ block.shopify_attributes }}>
            <div class="image-wrapper">
              {%- if block.settings.image != blank -%}
                <img
                  class="seasonal-card-img"
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt="{{ block.settings.title }}"
                  width="800" height="1067"
                  loading="lazy"
                >
              {%- else -%}
                {{- 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' -}}
              {%- endif -%}
              <div class="card-overlay-v2"></div>
            </div>

            <div class="card-content-v2">
              <span class="collection-label">COLLECTION</span>
              <h3 class="seasonal-card-name">{{ block.settings.title }}</h3>
              <p class="seasonal-card-desc">{{ block.settings.description }}</p>
              <span class="luxury-cta">
                SHOP NOW 
                <svg width="18" height="10" viewBox="0 0 18 10" fill="none"><path d="M13 1L17 5M17 5L13 9M17 5H1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </div>
        </a>
      </div>
    {%- endfor -%}
    </div>
  </div>
</section>

{% style %}
  /* ─── LUXURY EDITORIAL CSS ─── */
  :root {
    --gold-accent: #c5a059;
    --cream-bg: #f9f7f2;
    --dark-text: #1a1a1a;
  }

  .seasonal-v2-section {
    background-color: var(--cream-bg);
    overflow: hidden;
  }

  /* Header Styling */
  .section-header-v2 {
    text-align: center;
    margin-bottom: 10px; 
  }
  .section-header-v2 .eyebrow {
    font-family: 'Philosopher', sans-serif;
    letter-spacing: 0.3em;
    color: var(--gold-accent);
    font-size: 12px;
    display: block;
    margin-bottom: 10px;
    margin-top: 20px;
  }
  .section-header-v2 .section-title {
    font-family: 'Philosopher', sans-serif;
    font-size: clamp(32px, 4vw, 52px);
    color: var(--dark-text);
    margin: 0;
  }
  .section-header-v2 .accent-line {
    width: 50px;
    height: 1px;
    background: var(--gold-accent);
    margin: 10px auto;
  }

  /* Asymmetrical Grid */
  .seasonal-editorial-grid {
    display: flex;
    align-items: flex-start;
    gap: 20px; /* ← was 40px */
    max-width: 1400px;
    margin: 0 auto;
  }

  .seasonal-card-wrapper {
    position: relative;
    flex: 1;
  }

  /* Card Heights (Editorial Symmetry) */
  .card-size-1 { margin-top: 30px; }  /* ← was 60px */
  .card-size-2 { flex: 1.4; }
  .card-size-3 { margin-top: 50px; }  /* ← was 100px */

  /* Floating Mood Text */
  .floating-mood-text {
    position: absolute;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    left: -25px;
    top: 50px;
    font-family: 'Philosopher', sans-serif;
    text-transform: uppercase;
    font-size: 10px;
    letter-spacing: 0.4em;
    color: var(--dark-text);
    opacity: 0.4;
    z-index: 2;
  }

  /* The Card */
  .seasonal-card-v2 {
    display: block;
    text-decoration: none;
    position: relative;
    background: #fff;
    border-radius: 4px;
    transition: all 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .image-wrapper {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3/4.5;
    border-radius: 4px;
  }
  
  .card-size-2 .image-wrapper { aspect-ratio: 3/4; }

  .seasonal-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s ease;
  }

  .card-overlay-v2 {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 50%);
    opacity: 0.7;
    transition: opacity 0.4s ease;
  }

  /* Content */
  .card-content-v2 {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 24px 20px; /* ← was 40px 30px */
    color: #fff;
    z-index: 3;
  }

  .collection-label {
    font-size: 9px;
    letter-spacing: 0.3em;
    color: var(--gold-accent);
    margin-bottom: 8px;
    display: block;
  }

  .seasonal-card-name {
    font-family: 'Philosopher', sans-serif;
    font-size: clamp(18px, 2.8vw, 28px);
    margin-bottom: 12px;
    color: #fff !important;
  }

  .seasonal-card-desc {
    font-size: 13px;
    line-height: 1.5;
    color: rgba(255,255,255,0.7);
    margin-bottom: 20px;
    max-width: 250px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .luxury-cta {
    font-size: 11px;
    letter-spacing: 0.2em;
    font-weight: bold;
    display: flex;
    align-items: center;
    gap: 10px;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.4s ease;
  }

  /* Hover Effects */
  .seasonal-card-v2:hover {
    transform: translateY(-10px);
    box-shadow: 0 30px 60px rgba(0,0,0,0.15);
  }
  .seasonal-card-v2:hover .seasonal-card-img { transform: scale(1.1); }
  .seasonal-card-v2:hover .luxury-cta { opacity: 1; transform: translateY(0); }
  .seasonal-card-v2:hover .card-overlay-v2 { opacity: 0.9; }

  /* ── Tablet 700px–990px: 2 cards row 1, 1 card row 2 ── */
  @media (min-width: 700px) and (max-width: 990px) {
    .seasonal-editorial-grid {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 20px;
      padding: 0;
    }
    .card-size-1,
    .card-size-2,
    .card-size-3 {
      flex: 0 0 calc(50% - 10px);
      margin-top: 0;
    }
    /* All cards same height — override card-size-2's special ratio */
    .seasonal-editorial-grid .image-wrapper,
    .card-size-2 .image-wrapper {
      aspect-ratio: 3/4;
    }
    /* Center the lone 3rd card on row 2 */
    .seasonal-card-wrapper:last-child {
      margin-left: auto;
      margin-right: auto;
    }
    .floating-mood-text { display: none; }
    .luxury-cta { opacity: 1; transform: none; }
  }

  /* ── Mobile ≤699px: single column, equal card heights ── */
  @media (max-width: 699px) {
    .seasonal-editorial-grid {
      flex-direction: column;
      gap: 20px;
      padding: 0;
    }
    .card-size-1, .card-size-2, .card-size-3 {
      margin-top: 0;
      width: 100%;
    }
    /* Same height for every card — portrait keeps full image visible */
    .seasonal-editorial-grid .image-wrapper,
    .card-size-2 .image-wrapper {
      aspect-ratio: 3/4;
    }
    .floating-mood-text { display: none; }
    .luxury-cta { opacity: 1; transform: none; }
  }
{% endstyle %}

{% schema %}
{
  "name": "Seasonal Collections V2",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "Shop by Season"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Every season calls for a different scent"
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Editorial Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Collection name",
          "default": "Winter Collection"
        },
        {
          "type": "text",
          "id": "mood_text",
          "label": "Floating Mood Text",
          "info": "e.g., WARM & SMOKY"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Short description",
          "default": "Warm, rich scents crafted for cold evenings."
        },
        {
          "type": "url",
          "id": "collection_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Seasonal Editorial V2",
      "blocks": [
        { "type": "collection_card", "settings": { "title": "Winter Collection", "mood_text": "WARM & SMOKY" } },
        { "type": "collection_card", "settings": { "title": "Summer Collection", "mood_text": "FRESH CITRUS" } },
        { "type": "collection_card", "settings": { "title": "Monsoon Collection", "mood_text": "RAIN INSPIRED" } }
      ]
    }
  ]
}
{% endschema %}