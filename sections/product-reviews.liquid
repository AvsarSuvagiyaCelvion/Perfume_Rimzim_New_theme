<section class="product-reviews-section" id="ProductReviews">
  <div class="container">

    <div class="product-reviews-header animate-on-scroll">
      <div class="product-reviews-summary">
        <span class="section-label">Reviews</span>
        <h2 class="section-title">{{ section.settings.title | default: 'Write a Review' }}</h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="section-subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>
    </div>

  </div>

  <div id="trustoo-widget" class="container product-reviews-app">
    {%- for block in section.blocks -%}
      {%- if block.type == '@app' -%}
        {% render block %}
      {%- endif -%}
    {%- endfor -%}
  </div>

</section>

{% stylesheet %}
.product-reviews-section {
  padding: var(--space-80) 0;
}

.product-reviews-header {
  margin-bottom: var(--space-48);
}

.product-reviews-header .section-title {
  margin-bottom: 0;
}

.product-reviews-app {
  margin-top: var(--space-16);
}
{% endstylesheet %}

{% schema %}
{
  "name": "Product Reviews",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Write a Review"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "presets": [
    {
      "name": "Product Reviews"
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
