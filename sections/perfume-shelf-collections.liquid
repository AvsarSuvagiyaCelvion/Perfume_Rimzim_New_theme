<section class="psc-section" id="PerfumeShelfCollections-{{ section.id }}">
  <div class="psc-container">
    <div class="psc-layout">

      <!-- ══════════════════════════════
           LEFT — Illuminated Shelf
      ══════════════════════════════ -->
      <div class="psc-left">
        <div class="psc-cabinet" aria-live="polite" aria-label="Perfume display shelf">

          <div class="psc-shelf-sets">
            {%- for block in section.blocks -%}
              {%- liquid
                assign p           = all_products[block.settings.product]
                assign block_label = block.settings.title | default: p.title
              -%}
              <div
                class="psc-shelf-set{% if forloop.first %} psc-shelf-set--active{% endif %}"
                data-shelf="{{ block.id }}"
                aria-label="{{ block_label | escape }} shelf"
                {{ block.shopify_attributes }}
              >
                <!-- Top frame LED strip -->
                <div class="psc-frame-top"></div>

                <!-- Tier 1 — empty, ambient glow only -->
                <div class="psc-tier">
                  <div class="psc-tier-products psc-tier-products--empty"></div>
                  <div class="psc-plank"></div>
                </div>

                <!-- Tier 2 — featured bottle -->
                <div class="psc-tier">
                  <div class="psc-tier-products psc-tier-products--hero">
                    <div class="psc-slot psc-slot--hero">
                      {%- if p != blank and p.featured_image != blank -%}
                        <a href="{{ p.url }}" tabindex="-1" aria-label="{{ p.title | escape }}">
                          <img
                            src="{{ p.featured_image | image_url: width: 480, format: 'webp' }}"
                            alt="{{ p.featured_image.alt | default: p.title | escape }}"
                            loading="lazy"
                            width="240" height="320"
                          >
                        </a>
                      {%- else -%}
                        <div class="psc-slot-bottle psc-slot-bottle--hero" aria-hidden="true"></div>
                      {%- endif -%}
                    </div>
                  </div>
                  <div class="psc-plank"></div>
                </div>

                <!-- Tier 3 — empty, ambient glow only -->
                <div class="psc-tier">
                  <div class="psc-tier-products psc-tier-products--empty"></div>
                  <div class="psc-plank psc-plank--last"></div>
                </div>

              </div>
            {%- endfor -%}
          </div>

        </div>
      </div>

      <!-- ══════════════════════════════
           RIGHT — Category Tabs
      ══════════════════════════════ -->
      <div class="psc-right">
        <div class="psc-right-inner">

          {%- if section.settings.eyebrow != blank -%}
            <span class="psc-eyebrow">{{ section.settings.eyebrow }}</span>
          {%- endif -%}

          <h2 class="psc-heading">{{ section.settings.title }}</h2>

          <div class="psc-tabs" role="tablist">
            {%- for block in section.blocks -%}
              {%- liquid
                assign p         = all_products[block.settings.product]
                assign tab_title = block.settings.title | default: p.title
                assign tab_desc  = block.settings.description
                if tab_desc == blank
                  assign tab_desc = p.description | strip_html | truncate: 180
                endif
                assign tab_url = p.url | default: routes.all_products_collection_url
              -%}
              <div
                class="psc-tab{% if forloop.first %} psc-tab--active{% endif %}"
                data-tab="{{ block.id }}"
                role="tab"
                tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              >
                <h3 class="psc-tab-name">{{ tab_title }}</h3>
                <div class="psc-tab-body">
                  {%- if tab_desc != blank -%}
                    <p class="psc-tab-desc">{{ tab_desc }}</p>
                  {%- endif -%}
                  <a href="{{ tab_url }}" class="psc-tab-cta" tabindex="-1">
                    Shop Now
                    <svg width="16" height="8" viewBox="0 0 16 8" fill="none" aria-hidden="true">
                      <path d="M12 1L15 4M15 4L12 7M15 4H1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                </div>
              </div>
            {%- endfor -%}
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

{% style %}

/* ── Root tokens ── */
#PerfumeShelfCollections-{{ section.id }} {
  --psc-gold:       #c5a059;
  --psc-dark:       #1a1a1a;
  --psc-cream:      #f9f7f2;
  --psc-shelf-bg:   #1c1c1c;
  --psc-frame:      #e4e4e4;
  --psc-plank:      #dedede;
  --psc-led-color:  255, 200, 80;
}

/* ── Section wrapper ── */
.psc-section {
  background: var(--psc-cream);
  padding: 80px 0;
  overflow: hidden;
}

.psc-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 40px;
}

/* ── Two-column layout ── */
.psc-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 70px;
  align-items: center;
}

/* ════════════════════════════
   SHELF CABINET
════════════════════════════ */
.psc-left {
  position: relative;
}

.psc-cabinet {
  background: var(--psc-shelf-bg);
  border: 14px solid var(--psc-frame);
  box-shadow:
    0 0 0 1px #c8c8c8,
    0 40px 80px rgba(0, 0, 0, 0.25),
    inset 0 0 40px rgba(0, 0, 0, 0.6);
  position: relative;
}

/* Stack all shelf sets on top of each other */
.psc-shelf-sets {
  display: grid;
  grid-template-areas: "stack";
}

.psc-shelf-set {
  grid-area: stack;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.55s ease;
}

.psc-shelf-set--active {
  opacity: 1;
  pointer-events: auto;
}

/* Top frame LED strip */
.psc-frame-top {
  height: 10px;
  background: linear-gradient(to bottom, #e8e8e8, #d2d2d2);
  position: relative;
}

.psc-frame-top::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 8%; right: 8%;
  height: 2px;
  background: linear-gradient(
    to right,
    transparent,
    rgba(var(--psc-led-color), 0.9) 20%,
    rgba(var(--psc-led-color), 1)   50%,
    rgba(var(--psc-led-color), 0.9) 80%,
    transparent
  );
  box-shadow:
    0 0 8px 3px  rgba(var(--psc-led-color), 0.6),
    0 0 20px 8px rgba(var(--psc-led-color), 0.25);
}

/* ── Tiers ── */
.psc-tier {
  position: relative;
}

/* Empty tier — ambient glow, no product */
.psc-tier-products--empty {
  min-height: 80px;
  position: relative;
  z-index: 2;
  background: radial-gradient(
    ellipse 80% 60% at 50% 110%,
    rgba(var(--psc-led-color), 0.05),
    transparent 70%
  );
}

/* Hero tier — single featured bottle */
.psc-tier-products--hero {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 36px 24px 16px;
  min-height: 240px;
  position: relative;
  z-index: 2;
  background: radial-gradient(
    ellipse 60% 50% at 50% 110%,
    rgba(var(--psc-led-color), 0.09),
    transparent 70%
  );
}

.psc-slot--hero {
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.psc-slot--hero a {
  display: block;
}

.psc-slot--hero img {
  width: auto;
  height: 260px;
  max-width: 180px;
  object-fit: contain;
  object-position: bottom center;
  filter: drop-shadow(0 10px 24px rgba(0, 0, 0, 0.55));
  transition: transform 0.4s ease, filter 0.4s ease;
}

.psc-slot--hero img:hover {
  transform: translateY(-8px) scale(1.04);
  filter: drop-shadow(0 20px 32px rgba(0, 0, 0, 0.5));
}

/* Ghost bottle — hero size */
.psc-slot-bottle--hero {
  width: 80px;
  height: 220px;
  opacity: 0.18;
  background:
    linear-gradient(rgba(255,255,255,0.9), rgba(255,255,255,0.9))
      calc(50% - 12px) 0 / 24px 22px no-repeat,
    linear-gradient(rgba(255,255,255,0.65), rgba(255,255,255,0.65))
      calc(50% - 8px) 22px / 16px 28px no-repeat,
    linear-gradient(160deg, rgba(255,255,255,0.55), rgba(255,255,255,0.3))
      0 50px / 80px 170px no-repeat;
  border-radius: 0 0 10px 10px;
}

/* ── Shelf plank ── */
.psc-plank {
  height: 10px;
  background: linear-gradient(to bottom, #f0f0f0 0%, var(--psc-plank) 60%, #c4c4c4 100%);
  position: relative;
  z-index: 3;
  box-shadow: 0 2px 5px rgba(0, 0, 0, 0.3);
}

.psc-plank::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 8%; right: 8%;
  height: 2px;
  background: linear-gradient(
    to right,
    transparent,
    rgba(var(--psc-led-color), 0.9) 20%,
    rgba(var(--psc-led-color), 1)   50%,
    rgba(var(--psc-led-color), 0.9) 80%,
    transparent
  );
  box-shadow:
    0 0 6px 2px  rgba(var(--psc-led-color), 0.7),
    0 0 16px 6px rgba(var(--psc-led-color), 0.3);
}

/* Warm glow spreading downward from each LED plank */
.psc-plank::after {
  content: '';
  position: absolute;
  top: 100%;
  left: -2%; right: -2%;
  height: 65px;
  background: radial-gradient(
    ellipse 90% 100% at 50% 0%,
    rgba(var(--psc-led-color), 0.32) 0%,
    rgba(var(--psc-led-color), 0.10) 45%,
    transparent 100%
  );
  pointer-events: none;
  z-index: 0;
}

.psc-plank--last::after {
  display: none;
}

/* ════════════════════════════
   RIGHT PANEL — TABS
════════════════════════════ */
.psc-right {
  padding: 10px 0;
}

.psc-right-inner {
  max-width: 440px;
}

.psc-eyebrow {
  font-family: 'Philosopher', sans-serif;
  font-size: 11px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: #999;
  display: block;
  margin-bottom: 18px;
}

.psc-heading {
  font-family: 'Philosopher', serif;
  font-size: clamp(26px, 2.8vw, 42px);
  font-weight: 400;
  color: var(--psc-dark);
  line-height: 1.25;
  margin: 0 0 44px;
}

/* ── Tab list ── */
.psc-tabs {
  display: flex;
  flex-direction: column;
  border-left: 2px solid #e6e2d8;
}

/* ── Individual tab ── */
.psc-tab {
  padding: 14px 0 14px 26px;
  cursor: pointer;
  border-left: 3px solid transparent;
  margin-left: -2px;
  outline: none;
  transition: border-color 0.3s ease;
}

.psc-tab:focus-visible {
  border-left-color: var(--psc-gold);
  outline: 2px solid var(--psc-gold);
  outline-offset: 2px;
}

.psc-tab--active {
  border-left-color: var(--psc-dark);
}

.psc-tab-name {
  font-family: 'Philosopher', serif;
  font-size: 24px;
  font-weight: 400;
  color: #bbb;
  margin: 0;
  transition: color 0.3s ease, font-weight 0.1s;
  user-select: none;
}

.psc-tab--active .psc-tab-name {
  color: var(--psc-dark);
  font-weight: 700;
}

/* Animated accordion body */
.psc-tab-body {
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: max-height 0.4s ease, opacity 0.35s ease;
}

.psc-tab--active .psc-tab-body {
  max-height: 200px;
  opacity: 1;
}

.psc-tab-desc {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 15px;
  line-height: 1.7;
  color: var(--psc-gold);
  margin: 10px 0 18px;
}

.psc-tab-cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: 'Philosopher', sans-serif;
  font-size: 11px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--psc-dark);
  text-decoration: none;
  border-bottom: 1px solid currentColor;
  padding-bottom: 2px;
  transition: color 0.3s ease, gap 0.3s ease;
}

.psc-tab-cta:hover {
  color: var(--psc-gold);
  gap: 15px;
}

/* ════════════════════════════
   RESPONSIVE
════════════════════════════ */

@media (max-width: 990px) {
  .psc-layout {
    grid-template-columns: 1fr;
    gap: 44px;
  }
  .psc-right-inner {
    max-width: 100%;
  }
  .psc-heading {
    margin-bottom: 30px;
  }
  .psc-tier-products--empty {
    min-height: 55px;
  }
  .psc-tier-products--hero {
    min-height: 190px;
    padding: 28px 24px 12px;
  }
  .psc-slot--hero img {
    height: 170px;
  }
}

@media (max-width: 699px) {
  .psc-section {
    padding: 50px 0;
  }
  .psc-container {
    padding: 0 16px;
  }
  .psc-cabinet {
    border-width: 10px;
  }
  .psc-tier-products--empty {
    min-height: 44px;
  }
  .psc-tier-products--hero {
    min-height: 155px;
    padding: 20px 16px 10px;
  }
  .psc-slot--hero img {
    height: 130px;
  }
  .psc-tab-name {
    font-size: 20px;
  }
}

{% endstyle %}

<script>
(function () {
  const section = document.getElementById('PerfumeShelfCollections-{{ section.id }}');
  if (!section) return;

  const tabs    = section.querySelectorAll('.psc-tab');
  const shelves = section.querySelectorAll('.psc-shelf-set');
  const cabinet = section.querySelector('.psc-cabinet');

  function activate(tab, scrollToShelf) {
    const id = tab.dataset.tab;

    tabs.forEach(function (t) {
      t.classList.remove('psc-tab--active');
      t.setAttribute('aria-selected', 'false');
      t.setAttribute('tabindex', '-1');
      const cta = t.querySelector('.psc-tab-cta');
      if (cta) cta.setAttribute('tabindex', '-1');
    });

    tab.classList.add('psc-tab--active');
    tab.setAttribute('aria-selected', 'true');
    tab.setAttribute('tabindex', '0');
    const activeCta = tab.querySelector('.psc-tab-cta');
    if (activeCta) activeCta.removeAttribute('tabindex');

    shelves.forEach(function (s) {
      s.classList.remove('psc-shelf-set--active');
    });
    const target = section.querySelector('.psc-shelf-set[data-shelf="' + id + '"]');
    if (target) target.classList.add('psc-shelf-set--active');

    /* Mobile: scroll shelf into view after switching */
    if (scrollToShelf && cabinet && window.innerWidth <= 990) {
      setTimeout(function () {
        cabinet.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 60);
    }
  }

  tabs.forEach(function (tab) {
    tab.addEventListener('click', function () {
      activate(tab, true);
    });
    tab.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        activate(tab, true);
      }
      if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
        e.preventDefault();
        const all  = Array.from(tabs);
        const idx  = all.indexOf(tab);
        const next = e.key === 'ArrowDown'
          ? all[(idx + 1) % all.length]
          : all[(idx - 1 + all.length) % all.length];
        next.focus();
        activate(next, true);
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "Perfume Shelf Collections",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "COLLECTION"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Discover The Beauty Of Our Fragrance Collection"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product",
          "info": "This product's image appears as the single bottle on the shelf."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Tab title",
          "info": "Leave blank to use the product title."
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Tab description",
          "info": "Leave blank to use the product description."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Perfume Shelf Collections",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Men",
            "description": "Commanding, intense fragrances crafted for the modern gentleman."
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Women",
            "description": "Delicate, sophisticated scents designed to celebrate timeless elegance."
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Unisex",
            "description": "Boundary-free fragrances designed for every soul — bold, tender, and beautifully undefinable."
          }
        }
      ]
    }
  ]
}
{% endschema %}
