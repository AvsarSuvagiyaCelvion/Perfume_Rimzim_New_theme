<section class="psc-section" id="PerfumeShelfCollections-{{ section.id }}">
  <div class="psc-container">
    <div class="psc-layout">

      <!-- ══════════════════════════════
           LEFT — Display Cabinet
      ══════════════════════════════ -->
      <div class="psc-left">
        <div
          class="psc-cabinet{% if section.settings.cabinet_bg %} psc-cabinet--has-bg{% endif %}"
          aria-live="polite"
          aria-label="Perfume display cabinet"
        >

          {%- if section.settings.cabinet_bg -%}
            <!-- Background shelf image -->
            <div class="psc-cabinet-bg" aria-hidden="true">
              <img
                src="{{ section.settings.cabinet_bg | image_url: width: 900, format: 'webp' }}"
                alt=""
                loading="lazy"
                width="900"
                height="900"
              >
            </div>
          {%- endif -%}

          <div class="psc-shelf-sets">
            {%- for block in section.blocks -%}
              {%- liquid
                assign p           = all_products[block.settings.product]
                assign block_label = block.settings.title | default: p.title
              -%}
              <div
                class="psc-shelf-set{% if forloop.first %} psc-shelf-set--active{% endif %}"
                data-shelf="{{ block.id }}"
                aria-label="{{ block_label | escape }} display"
                {{ block.shopify_attributes }}
              >

                {%- if section.settings.cabinet_bg -%}

                  <!-- ── BG IMAGE MODE: bottle floating on photo ── -->
                  <div class="psc-bottle-on-bg">
                    {%- if p != blank and p.featured_image != blank -%}
                      <a href="{{ p.url }}" tabindex="-1" aria-label="{{ p.title | escape }}">
                        <img
                          src="{{ p.featured_image | image_url: width: 480, format: 'webp' }}"
                          alt="{{ p.featured_image.alt | default: p.title | escape }}"
                          loading="lazy"
                          width="200" height="300"
                        >
                      </a>
                    {%- else -%}
                      <div class="psc-ghost-bottle" aria-hidden="true"></div>
                    {%- endif -%}
                  </div>

                {%- else -%}

                  <!-- ── CSS NICHE MODE: dark wood cabinet ── -->
                  <div class="psc-niche-wrap">

                    <div class="psc-niche-row psc-niche-row--top">
                      <div class="psc-niche psc-niche--sm"></div>
                      <div class="psc-niche psc-niche--sm"></div>
                      <div class="psc-niche psc-niche--sm"></div>
                    </div>

                    <div class="psc-niche-row psc-niche-row--mid">
                      <div class="psc-niche-col">
                        <div class="psc-niche psc-niche--side"></div>
                        <div class="psc-niche psc-niche--side"></div>
                      </div>
                      <div class="psc-niche psc-niche--center">
                        {%- if p != blank and p.featured_image != blank -%}
                          <a href="{{ p.url }}" tabindex="-1" aria-label="{{ p.title | escape }}">
                            <img
                              src="{{ p.featured_image | image_url: width: 480, format: 'webp' }}"
                              alt="{{ p.featured_image.alt | default: p.title | escape }}"
                              loading="lazy"
                              width="200" height="300"
                            >
                          </a>
                        {%- else -%}
                          <div class="psc-ghost-bottle" aria-hidden="true"></div>
                        {%- endif -%}
                      </div>
                      <div class="psc-niche-col">
                        <div class="psc-niche psc-niche--side"></div>
                        <div class="psc-niche psc-niche--side"></div>
                      </div>
                    </div>

                    <div class="psc-niche-row psc-niche-row--bot">
                      <div class="psc-niche psc-niche--bot"></div>
                      <div class="psc-niche psc-niche--bot psc-niche--bot-wide"></div>
                    </div>

                  </div>

                {%- endif -%}

              </div>
            {%- endfor -%}
          </div>

        </div>
      </div>

      <!-- ══════════════════════════════
           RIGHT — Category Tabs
      ══════════════════════════════ -->
      <div class="psc-right">
        <div class="psc-right-inner">

          {%- if section.settings.eyebrow != blank -%}
            <span class="psc-eyebrow">{{ section.settings.eyebrow }}</span>
          {%- endif -%}

          <h2 class="psc-heading">{{ section.settings.title }}</h2>

          <div class="psc-tabs" role="tablist">
            {%- for block in section.blocks -%}
              {%- liquid
                assign p         = all_products[block.settings.product]
                assign tab_title = block.settings.title | default: p.title
                assign tab_desc  = block.settings.description
                if tab_desc == blank
                  assign tab_desc = p.description | strip_html | truncate: 180
                endif
                assign tab_url = p.url | default: routes.all_products_collection_url
              -%}
              <div
                class="psc-tab{% if forloop.first %} psc-tab--active{% endif %}"
                data-tab="{{ block.id }}"
                role="tab"
                tabindex="{% if forloop.first %}0{% else %}-1{% endif %}"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              >
                <h3 class="psc-tab-name">{{ tab_title }}</h3>
                <div class="psc-tab-body">
                  {%- if tab_desc != blank -%}
                    <p class="psc-tab-desc">{{ tab_desc }}</p>
                  {%- endif -%}
                  <a href="{{ tab_url }}" class="psc-tab-cta" tabindex="-1">
                    Shop Now
                    <svg width="16" height="8" viewBox="0 0 16 8" fill="none" aria-hidden="true">
                      <path d="M12 1L15 4M15 4L12 7M15 4H1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                </div>
              </div>
            {%- endfor -%}
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

{% style %}

#PerfumeShelfCollections-{{ section.id }} {
  --psc-gold:       #c5a059;
  --psc-dark:       #1a1a1a;
  --psc-cream:      #f9f7f2;
  --psc-wood:       #150d06;
  --psc-wood-mid:   #1f1408;
  --psc-niche-wall: #cfc4ae;
  --psc-niche-gap:  12px;
  --psc-spot:       255, 210, 120;
  --psc-bottle-y:   {{ section.settings.bottle_position }}%;
}

.psc-section {
  background: var(--psc-cream);
  padding: 80px 0;
  overflow: hidden;
}

.psc-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 40px;
}

.psc-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 70px;
  align-items: center;
}

/* ════════════════════════════
   CABINET — BASE
════════════════════════════ */
.psc-left { position: relative; }

.psc-cabinet {
  background: var(--psc-wood);
  padding: var(--psc-niche-gap);
  box-shadow:
    inset 0 0 0 4px var(--psc-wood-mid),
    0 40px 80px rgba(0, 0, 0, 0.5);
  position: relative;
}

/* ════════════════════════════
   CABINET — BACKGROUND IMAGE MODE
════════════════════════════ */
.psc-cabinet--has-bg {
  padding: 0;
  background: #111;
  overflow: hidden;
}

.psc-cabinet-bg {
  display: block;
  line-height: 0;
}

.psc-cabinet-bg img {
  width: 100%;
  height: auto;
  display: block;
  object-fit: cover;
}

/* Shelf sets sit on top of the photo */
.psc-cabinet--has-bg .psc-shelf-sets {
  position: absolute;
  inset: 0;
}

.psc-cabinet--has-bg .psc-shelf-set {
  position: absolute;
  inset: 0;
  display: flex;
  justify-content: center;
  align-items: flex-end;
  padding-bottom: var(--psc-bottle-y);
}

/* Bottle floating on shelf photo */
.psc-bottle-on-bg {
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.psc-bottle-on-bg a { display: block; }

.psc-bottle-on-bg img {
  width: auto;
  height: 220px;
  max-width: 160px;
  object-fit: contain;
  object-position: bottom center;
  filter: drop-shadow(0 10px 20px rgba(0, 0, 0, 0.55));
  transition: transform 0.4s ease, filter 0.4s ease;
}

.psc-bottle-on-bg img:hover {
  transform: translateY(-8px) scale(1.05);
  filter: drop-shadow(0 20px 32px rgba(0, 0, 0, 0.5));
}

/* ════════════════════════════
   SHELF-SET STACKING (both modes)
════════════════════════════ */
.psc-shelf-sets {
  display: grid;
  grid-template-areas: "stack";
}

.psc-shelf-set {
  grid-area: stack;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.55s ease;
}

.psc-shelf-set--active {
  opacity: 1;
  pointer-events: auto;
}

/* ════════════════════════════
   CSS NICHE MODE — DARK WOOD
════════════════════════════ */
.psc-niche-wrap {
  display: flex;
  flex-direction: column;
  gap: var(--psc-niche-gap);
}

.psc-niche-row {
  display: flex;
  gap: var(--psc-niche-gap);
}

.psc-niche-row--top .psc-niche--sm {
  flex: 1;
  height: 72px;
}

.psc-niche-row--mid { align-items: stretch; }

.psc-niche-col {
  flex: 0 0 22%;
  display: flex;
  flex-direction: column;
  gap: var(--psc-niche-gap);
}

.psc-niche-col .psc-niche--side { flex: 1; min-height: 90px; }

.psc-niche--center {
  flex: 1;
  min-height: 280px;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 18px;
}

.psc-niche-row--bot .psc-niche--bot { flex: 1; height: 68px; }
.psc-niche--bot-wide { flex: 1.5 !important; }

/* Individual niche */
.psc-niche {
  background: var(--psc-niche-wall);
  position: relative;
  overflow: hidden;
}

.psc-niche::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(
    ellipse 85% 55% at 50% -8%,
    rgba(var(--psc-spot), 0.88) 0%,
    rgba(var(--psc-spot), 0.38) 38%,
    transparent 68%
  );
  pointer-events: none;
  z-index: 1;
}

.psc-niche::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 50%;
  background: linear-gradient(to top, rgba(0,0,0,0.28) 0%, transparent 100%);
  pointer-events: none;
  z-index: 1;
}

.psc-niche--center {
  background: linear-gradient(to bottom, #c0b49c 0%, #cec3ad 20%, #d4c9b3 60%, #bfb49d 100%);
  box-shadow: inset 4px 0 12px rgba(0,0,0,0.15), inset -4px 0 12px rgba(0,0,0,0.15);
}

.psc-niche--center::before {
  background: radial-gradient(
    ellipse 70% 60% at 50% -5%,
    rgba(var(--psc-spot), 1) 0%,
    rgba(var(--psc-spot), 0.55) 35%,
    transparent 65%
  );
}

.psc-niche--center a {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  position: relative;
  z-index: 2;
}

.psc-niche--center img {
  width: auto;
  height: 210px;
  max-width: 140px;
  object-fit: contain;
  object-position: bottom center;
  filter: drop-shadow(0 8px 16px rgba(0,0,0,0.45)) drop-shadow(0 2px 4px rgba(0,0,0,0.3));
  transition: transform 0.4s ease, filter 0.4s ease;
  position: relative;
  z-index: 2;
}

.psc-niche--center img:hover {
  transform: translateY(-8px) scale(1.05);
  filter: drop-shadow(0 18px 28px rgba(0,0,0,0.5));
}

.psc-ghost-bottle {
  width: 60px;
  height: 180px;
  opacity: 0.2;
  background:
    linear-gradient(rgba(80,60,30,0.8), rgba(80,60,30,0.8))
      calc(50% - 9px) 0 / 18px 18px no-repeat,
    linear-gradient(rgba(80,60,30,0.6), rgba(80,60,30,0.6))
      calc(50% - 6px) 18px / 12px 22px no-repeat,
    linear-gradient(150deg, rgba(80,60,30,0.55), rgba(80,60,30,0.3))
      0 40px / 60px 140px no-repeat;
  border-radius: 0 0 8px 8px;
  position: relative;
  z-index: 2;
  flex-shrink: 0;
}

/* ════════════════════════════
   RIGHT PANEL — TABS
════════════════════════════ */
.psc-right { padding: 10px 0; }
.psc-right-inner { max-width: 440px; }

.psc-eyebrow {
  font-family: 'Philosopher', sans-serif;
  font-size: 11px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: #999;
  display: block;
  margin-bottom: 18px;
}

.psc-heading {
  font-family: 'Philosopher', serif;
  font-size: clamp(26px, 2.8vw, 42px);
  font-weight: 400;
  color: var(--psc-dark);
  line-height: 1.25;
  margin: 0 0 44px;
}

.psc-tabs {
  display: flex;
  flex-direction: column;
  border-left: 2px solid #e6e2d8;
}

.psc-tab {
  padding: 14px 0 14px 26px;
  cursor: pointer;
  border-left: 3px solid transparent;
  margin-left: -2px;
  outline: none;
  transition: border-color 0.3s ease;
}

.psc-tab:focus-visible {
  border-left-color: var(--psc-gold);
  outline: 2px solid var(--psc-gold);
  outline-offset: 2px;
}

.psc-tab--active { border-left-color: var(--psc-dark); }

.psc-tab-name {
  font-family: 'Philosopher', serif;
  font-size: 24px;
  font-weight: 400;
  color: #bbb;
  margin: 0;
  transition: color 0.3s ease;
  user-select: none;
}

.psc-tab--active .psc-tab-name { color: var(--psc-dark); font-weight: 700; }

.psc-tab-body {
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: max-height 0.4s ease, opacity 0.35s ease;
}

.psc-tab--active .psc-tab-body { max-height: 200px; opacity: 1; }

.psc-tab-desc {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 15px;
  line-height: 1.7;
  color: var(--psc-gold);
  margin: 10px 0 18px;
}

.psc-tab-cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: 'Philosopher', sans-serif;
  font-size: 11px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--psc-dark);
  text-decoration: none;
  border-bottom: 1px solid currentColor;
  padding-bottom: 2px;
  transition: color 0.3s ease, gap 0.3s ease;
}

.psc-tab-cta:hover { color: var(--psc-gold); gap: 15px; }

/* ════════════════════════════
   RESPONSIVE
════════════════════════════ */
@media (max-width: 990px) {
  .psc-layout { grid-template-columns: 1fr; gap: 44px; }
  .psc-right-inner { max-width: 100%; }
  .psc-heading { margin-bottom: 30px; }
  .psc-bottle-on-bg img { height: 170px; }
  .psc-niche--center { min-height: 210px; }
  .psc-niche--center img { height: 160px; }
  .psc-niche-row--top .psc-niche--sm { height: 54px; }
  .psc-niche-row--bot .psc-niche--bot { height: 50px; }
}

@media (max-width: 699px) {
  .psc-section { padding: 50px 0; }
  .psc-container { padding: 0 16px; }
  .psc-bottle-on-bg img { height: 130px; }
  .psc-niche-col { flex-basis: 18%; }
  .psc-niche--center { min-height: 175px; padding-bottom: 12px; }
  .psc-niche--center img { height: 130px; }
  .psc-niche-row--top .psc-niche--sm { height: 42px; }
  .psc-niche-col .psc-niche--side { min-height: 65px; }
  .psc-niche-row--bot .psc-niche--bot { height: 40px; }
  .psc-tab-name { font-size: 20px; }
}

{% endstyle %}

<script>
(function () {
  const section = document.getElementById('PerfumeShelfCollections-{{ section.id }}');
  if (!section) return;

  const tabs    = section.querySelectorAll('.psc-tab');
  const shelves = section.querySelectorAll('.psc-shelf-set');
  const cabinet = section.querySelector('.psc-cabinet');

  function activate(tab, scrollToShelf) {
    const id = tab.dataset.tab;

    tabs.forEach(function (t) {
      t.classList.remove('psc-tab--active');
      t.setAttribute('aria-selected', 'false');
      t.setAttribute('tabindex', '-1');
      const cta = t.querySelector('.psc-tab-cta');
      if (cta) cta.setAttribute('tabindex', '-1');
    });

    tab.classList.add('psc-tab--active');
    tab.setAttribute('aria-selected', 'true');
    tab.setAttribute('tabindex', '0');
    const activeCta = tab.querySelector('.psc-tab-cta');
    if (activeCta) activeCta.removeAttribute('tabindex');

    shelves.forEach(function (s) {
      s.classList.remove('psc-shelf-set--active');
    });
    const target = section.querySelector('.psc-shelf-set[data-shelf="' + id + '"]');
    if (target) target.classList.add('psc-shelf-set--active');

    if (scrollToShelf && cabinet && window.innerWidth <= 990) {
      setTimeout(function () {
        cabinet.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 60);
    }
  }

  tabs.forEach(function (tab) {
    tab.addEventListener('click', function () { activate(tab, true); });
    tab.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        activate(tab, true);
      }
      if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
        e.preventDefault();
        const all  = Array.from(tabs);
        const idx  = all.indexOf(tab);
        const next = e.key === 'ArrowDown'
          ? all[(idx + 1) % all.length]
          : all[(idx - 1 + all.length) % all.length];
        next.focus();
        activate(next, true);
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "Perfume Shelf Collections",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "COLLECTION"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Discover The Beauty Of Our Fragrance Collection"
    },
    {
      "type": "header",
      "content": "Cabinet Background"
    },
    {
      "type": "image_picker",
      "id": "cabinet_bg",
      "label": "Cabinet background image",
      "info": "Upload a shelf/cabinet photo. Your product bottle will appear on top of it. Leave blank to use the built-in CSS cabinet design."
    },
    {
      "type": "range",
      "id": "bottle_position",
      "label": "Bottle vertical position",
      "info": "How far from the bottom the bottle sits on the shelf image (%).",
      "min": 5,
      "max": 50,
      "step": 1,
      "default": 18
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product",
          "info": "This product's image appears as the featured bottle."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Tab title",
          "info": "Leave blank to use the product title."
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Tab description",
          "info": "Leave blank to use the product description."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Perfume Shelf Collections",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Men",
            "description": "Commanding, intense fragrances crafted for the modern gentleman."
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Women",
            "description": "Delicate, sophisticated scents designed to celebrate timeless elegance."
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Unisex",
            "description": "Boundary-free fragrances designed for every soul — bold, tender, and beautifully undefinable."
          }
        }
      ]
    }
  ]
}
{% endschema %}
