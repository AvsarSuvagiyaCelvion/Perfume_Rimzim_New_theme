{%- liquid
  assign sort_by      = collection.sort_by | default: collection.default_sort_by
  assign per_page     = section.settings.products_per_page | default: 12
-%}

{%- paginate collection.products by per_page -%}

<section class="main-collection-section" id="MainCollection">
  <div class="container">

    {%- comment -%} -- Toolbar: count + sort -- {%- endcomment -%}
    <div class="collection-toolbar">
      <p class="collection-count">
        <span>{{ collection.products_count }}</span>
        {{ collection.products_count | pluralize: 'product', 'products' }}
      </p>

      <div class="collection-sort">
        <label for="CollectionSort" class="collection-sort-label">Sort by</label>
        <div class="collection-sort-select-wrap">
          <select
            id="CollectionSort"
            class="collection-sort-select"
            name="sort_by"
            aria-label="Sort products"
          >
            {%- for option in collection.sort_options -%}
              <option
                value="{{ option.value }}"
                {%- if option.value == sort_by %} selected{%- endif -%}
              >{{ option.name }}</option>
            {%- endfor -%}
          </select>
          <svg class="collection-sort-chevron" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="14" height="14" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
          </svg>
        </div>
      </div>
    </div>

    {%- comment -%} -- Product Grid -- {%- endcomment -%}
    {%- if collection.products.size > 0 -%}
      {%- assign col_badge_labels = 'Trending,Hot Pick,Best Seller,Fan Fave,Top Rated,New Hit,Must Have,Editor Pick' | split: ',' -%}
      <div class="trending-grid" id="CollectionGrid">
        {%- for product in collection.products -%}
          {%- liquid
            assign first_variant = product.selected_or_first_available_variant
            assign badge_index   = forloop.index0 | modulo: 8
            assign badge_label   = col_badge_labels[badge_index]
          -%}

          <div class="tcard animate-on-scroll" data-delay="{{ forloop.index0 | times: 60 }}">

            <a href="{{ product.url }}" class="tcard-full-link" aria-label="{{ product.title | escape }}"></a>

            <div class="tcard-media">
              <a href="{{ product.url }}" class="tcard-img-link" tabindex="-1" aria-hidden="true">
                {%- liquid
                  if product.images.size > 2
                    assign primary_img = product.images[2]
                    assign hover_img   = product.images[1]
                  elsif product.images.size > 1
                    assign primary_img = product.featured_image
                    assign hover_img   = product.images[1]
                  else
                    assign primary_img = product.featured_image
                    assign hover_img   = nil
                  endif
                -%}
                {%- if primary_img != blank -%}
                  <img
                    class="tcard-img"
                    src="{{ primary_img | image_url: width: 480, format: 'webp' }}"
                    srcset="{{ primary_img | image_url: width: 320, format: 'webp' }} 320w,
                            {{ primary_img | image_url: width: 480, format: 'webp' }} 480w"
                    sizes="(max-width: 600px) 50vw, 25vw"
                    alt="{{ primary_img.alt | default: product.title | escape }}"
                    width="480" height="480" loading="lazy"
                  >
                  {%- if hover_img != blank -%}
                    <img
                      class="tcard-img tcard-img--hover"
                      src="{{ hover_img | image_url: width: 480, format: 'webp' }}"
                      alt="{{ hover_img.alt | default: product.title | escape }}"
                      width="480" height="480" loading="lazy"
                      aria-hidden="true"
                    >
                  {%- endif -%}
                {%- else -%}
                  {{- 'product-1' | placeholder_svg_tag: 'tcard-img' -}}
                {%- endif -%}
              </a>

              {% comment %} <span class="tcard-badge">{{ badge_label }}</span> {% endcomment %}

              <button
                class="tcard-wishlist product-card-wishlist"
                aria-label="Add {{ product.title | escape }} to wishlist"
                data-handle="{{ product.handle }}"
                data-title="{{ product.title | escape }}"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
                </svg>
              </button>

            </div>

            <div class="tcard-body">
              <a href="{{ product.url }}" class="tcard-name">{{ product.title }}</a>

              <div class="tcard-reviews">
                {%- liquid
                  assign jdgm_badge = product.metafields.judgeme.badge
                  assign show_real_badge = false
                  if jdgm_badge != blank
                    unless jdgm_badge contains 'data-number-of-reviews="0'
                      assign show_real_badge = true
                    endunless
                  endif
                -%}
                {%- if show_real_badge -%}
                  {{ jdgm_badge }}
                {%- else -%}
                  <div class="tcard-stars" role="img" aria-label="No reviews yet" style="--rating: 0%">
                    <span class="stars-filled" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
                    <span class="stars-empty" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
                  </div>
                  <span class="tcard-review-count">0 reviews</span>
                {%- endif -%}
              </div>

              <div class="tcard-price">
                <span class="tcard-price-current">{{ product.price | money }}</span>
                {%- if product.compare_at_price > product.price -%}
                  <s class="tcard-price-compare">{{ product.compare_at_price | money }}</s>
                {%- endif -%}
              </div>

              {%- if product.available -%}
                <button
                  class="tcard-quick-add product-quick-add-btn"
                  type="button"
                  data-variant-id="{{ first_variant.id }}"
                  data-has-variants="{{ product.variants.size | minus: 1 | at_least: 0 }}"
                  data-handle="{{ product.handle }}"
                  data-title="{{ product.title | escape }}"
                  data-product-url="{{ product.url }}"
                  aria-label="Quick add {{ product.title | escape }}"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="14" height="14" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
                  </svg>
                  Quick Add
                </button>
              {%- else -%}
                <span class="tcard-soldout-btn">Sold Out</span>
              {%- endif -%}
            </div>

          </div>
        {%- endfor -%}
      </div>

      {%- comment -%} -- Pagination -- {%- endcomment -%}
      {%- if paginate.pages > 1 -%}
        <nav class="collection-pagination" aria-label="Pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="pagination-btn pagination-prev" aria-label="Previous page">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
              </svg>
            </a>
          {%- endif -%}

          <div class="pagination-pages">
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="pagination-page">{{ part.title }}</a>
              {%- elsif part.title == paginate.current_page -%}
                <span class="pagination-page is-current" aria-current="page">{{ part.title }}</span>
              {%- else -%}
                <span class="pagination-ellipsis">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
          </div>

          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="pagination-btn pagination-next" aria-label="Next page">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
              </svg>
            </a>
          {%- endif -%}
        </nav>
      {%- endif -%}

    {%- else -%}
      {%- comment -%} Empty collection {%- endcomment -%}
      <div class="collection-empty">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" width="64" height="64" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007z"/>
        </svg>
        <h2>No products found</h2>
        <p>This collection doesn't have any products yet.</p>
        <a href="{{ routes.collections_url }}" class="btn btn-primary">Browse all collections</a>
      </div>
    {%- endif -%}

  </div>
</section>

{%- endpaginate -%}

<script>
  (function () {
    var sel = document.getElementById('CollectionSort');
    if (!sel) return;
    sel.addEventListener('change', function () {
      var url = new URL(window.location.href);
      url.searchParams.set('sort_by', sel.value);
      url.searchParams.delete('page');
      window.location.href = url.toString();
    });
  })();
</script>

{% schema %}
{
  "name": "Collection Products",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 24,
      "step": 4,
      "default": 12
    }
  ]
}
{% endschema %}
