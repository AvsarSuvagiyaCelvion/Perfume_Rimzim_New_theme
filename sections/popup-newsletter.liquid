{% comment %}
  Section: Newsletter Popup
  Purpose: Email capture popup with discount offer
  Used in: layout/theme.liquid (rendered on all pages or homepage only)
  Metafield dependencies: none
{% endcomment %}

{%- liquid
  assign show_on_homepage_only = section.settings.homepage_only
  assign frequency              = section.settings.frequency
  assign delay                  = section.settings.delay | default: 3
-%}

{%- if show_on_homepage_only == false or template.name == 'index' -%}

<div
  class="pnl-backdrop"
  id="PopupBackdrop"
  aria-hidden="true"
  data-frequency="{{ frequency }}"
  data-delay="{{ delay }}"
></div>

<div
  class="pnl-popup"
  id="PopupNewsletter"
  role="dialog"
  aria-modal="true"
  aria-labelledby="PopupHeading"
  aria-hidden="true"
>
  <button class="pnl-close" id="PopupClose" aria-label="Close popup">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>

  <div class="pnl-inner">

    {%- comment -%} Left — image {%- endcomment -%}
    {%- if section.settings.image != blank -%}
      <div class="pnl-img-col">
        <img
          src="{{ section.settings.image | image_url: width: 600, format: 'webp' }}"
          alt="{{ section.settings.image.alt | default: shop.name | escape }}"
          width="600" height="800"
          loading="eager"
          class="pnl-img"
        >
      </div>
    {%- endif -%}

    {%- comment -%} Right — content {%- endcomment -%}
    <div class="pnl-content">

      {%- if section.settings.eyebrow != blank -%}
        <p class="pnl-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      <h2 class="pnl-heading" id="PopupHeading">{{ section.settings.heading | escape }}</h2>

      {%- if section.settings.subtext != blank -%}
        <p class="pnl-subtext">{{ section.settings.subtext | escape }}</p>
      {%- endif -%}

      {%- comment -%} Signup form {%- endcomment -%}
      <div class="pnl-form-wrap" id="PopupFormWrap">
        <form class="pnl-form" id="PopupForm" novalidate>
          <div class="pnl-input-row">
            <input
              type="email"
              name="contact[email]"
              id="PopupEmail"
              class="pnl-input"
              placeholder="{{ section.settings.placeholder | default: 'Enter your email' | escape }}"
              autocomplete="email"
              required
              aria-label="Email address"
            >
            <button type="submit" class="pnl-btn" id="PopupSubmit">
              {{ section.settings.button_text | default: 'Claim Offer' | escape }}
            </button>
          </div>
          <p class="pnl-error" id="PopupError" aria-live="polite"></p>
        </form>
        <p class="pnl-fine-print">{{ section.settings.fine_print | escape }}</p>
      </div>

      {%- comment -%} Success state {%- endcomment -%}
      <div class="pnl-success" id="PopupSuccess" aria-live="polite">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="40" height="40" class="pnl-success-icon">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <p class="pnl-success-title">{{ section.settings.success_title | escape }}</p>
        {%- if section.settings.discount_code != blank -%}
          <p class="pnl-success-sub">{{ section.settings.success_sub | escape }}</p>
          <div class="pnl-code-box" id="PopupCode">
            <span class="pnl-code">{{ section.settings.discount_code | escape }}</span>
            <button class="pnl-copy-btn" id="PopupCopyBtn" type="button" aria-label="Copy code">Copy</button>
          </div>
        {%- else -%}
          <p class="pnl-success-sub">{{ section.settings.success_sub | escape }}</p>
        {%- endif -%}
        <button class="pnl-btn pnl-btn--outline" id="PopupSuccessClose" type="button">
          {{ section.settings.success_cta | default: 'Start Shopping' | escape }}
        </button>
      </div>

    </div>
  </div>
</div>

<style>
  .pnl-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    z-index: 9998;
    opacity: 0;
    transition: opacity 0.35s ease;
  }
  .pnl-backdrop.is-open {
    display: block;
    opacity: 1;
  }

  .pnl-popup {
    display: none;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -48%);
    z-index: 9999;
    width: min(92vw, 820px);
    max-height: 90vh;
    overflow-y: auto;
    background: var(--color-dark, #111);
    border: 1px solid rgba(201,169,110,0.25);
    border-radius: var(--radius-lg, 16px);
    opacity: 0;
    transition: opacity 0.35s ease, transform 0.35s cubic-bezier(0.34,1.56,0.64,1);
  }
  .pnl-popup.is-open {
    display: block;
    opacity: 1;
    transform: translate(-50%, -50%);
  }

  @media (prefers-reduced-motion: reduce) {
    .pnl-popup, .pnl-backdrop { transition: none; }
  }

  .pnl-close {
    position: absolute;
    top: var(--space-16, 16px);
    right: var(--space-16, 16px);
    background: rgba(255,255,255,0.08);
    border: none;
    border-radius: var(--radius-full, 9999px);
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: rgba(255,255,255,0.7);
    z-index: 1;
    transition: background 0.2s, color 0.2s;
  }
  .pnl-close:hover { background: rgba(255,255,255,0.15); color: #fff; }

  .pnl-inner {
    display: flex;
    min-height: 420px;
  }

  .pnl-img-col {
    flex: 0 0 42%;
    overflow: hidden;
    border-radius: var(--radius-lg, 16px) 0 0 var(--radius-lg, 16px);
  }
  .pnl-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 600px) {
    .pnl-img-col { display: none; }
  }

  .pnl-content {
    flex: 1;
    padding: var(--space-48, 48px) var(--space-40, 40px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-12, 12px);
  }
  @media (max-width: 600px) {
    .pnl-content { padding: var(--space-40, 40px) var(--space-24, 24px); }
  }

  .pnl-eyebrow {
    font-family: var(--font-body, sans-serif);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-primary, #C9A96E);
    margin: 0;
  }
  .pnl-heading {
    font-family: var(--font-heading, serif);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 400;
    color: #fff;
    line-height: 1.2;
    margin: 0;
  }
  .pnl-subtext {
    font-family: var(--font-body, sans-serif);
    font-size: 0.9rem;
    color: rgba(255,255,255,0.6);
    margin: 0;
    line-height: 1.6;
  }

  .pnl-input-row {
    display: flex;
    gap: var(--space-8, 8px);
    margin-top: var(--space-8, 8px);
  }
  @media (max-width: 420px) {
    .pnl-input-row { flex-direction: column; }
  }

  .pnl-input {
    flex: 1;
    padding: var(--space-12, 12px) var(--space-16, 16px);
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: var(--radius-md, 8px);
    color: #fff;
    font-family: var(--font-body, sans-serif);
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.2s;
    min-width: 0;
  }
  .pnl-input::placeholder { color: rgba(255,255,255,0.35); }
  .pnl-input:focus { border-color: var(--color-primary, #C9A96E); }

  .pnl-btn {
    padding: var(--space-12, 12px) var(--space-24, 24px);
    background: var(--color-primary, #C9A96E);
    color: var(--color-dark, #111);
    border: none;
    border-radius: var(--radius-md, 8px);
    font-family: var(--font-body, sans-serif);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s, transform 0.15s;
  }
  .pnl-btn:hover { background: var(--color-primary-dark, #A8894E); transform: translateY(-1px); }
  .pnl-btn--outline {
    background: transparent;
    color: var(--color-primary, #C9A96E);
    border: 1px solid var(--color-primary, #C9A96E);
    margin-top: var(--space-8, 8px);
  }
  .pnl-btn--outline:hover { background: rgba(201,169,110,0.1); }

  .pnl-error {
    color: #ff6b6b;
    font-size: 0.8rem;
    margin: var(--space-4, 4px) 0 0;
    min-height: 1.2em;
  }
  .pnl-fine-print {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.3);
    margin: var(--space-4, 4px) 0 0;
  }

  .pnl-success {
    display: none;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-8, 8px);
    padding-top: var(--space-8, 8px);
  }
  .pnl-success.is-visible { display: flex; }
  .pnl-success-icon { color: var(--color-primary, #C9A96E); }
  .pnl-success-title {
    font-family: var(--font-heading, serif);
    font-size: 1.3rem;
    color: #fff;
    margin: 0;
  }
  .pnl-success-sub {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.6);
    margin: 0;
  }

  .pnl-code-box {
    display: flex;
    align-items: center;
    gap: var(--space-8, 8px);
    background: rgba(201,169,110,0.12);
    border: 1px dashed var(--color-primary, #C9A96E);
    border-radius: var(--radius-md, 8px);
    padding: var(--space-12, 12px) var(--space-16, 16px);
    margin-top: var(--space-4, 4px);
  }
  .pnl-code {
    font-family: var(--font-body, monospace);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-primary, #C9A96E);
  }
  .pnl-copy-btn {
    font-size: 0.75rem;
    padding: 4px 10px;
    background: var(--color-primary, #C9A96E);
    color: #111;
    border: none;
    border-radius: var(--radius-sm, 4px);
    cursor: pointer;
    font-weight: 700;
    letter-spacing: 0.05em;
    transition: background 0.2s;
  }
  .pnl-copy-btn:hover { background: var(--color-primary-dark, #A8894E); }
</style>

<script>
(function () {
  var STORAGE_KEY = 'pnl_seen';

  function shouldShow(frequency) {
    if (frequency === 'always') return true;
    if (frequency === 'session') return !sessionStorage.getItem(STORAGE_KEY);
    if (frequency === 'once')    return !localStorage.getItem(STORAGE_KEY);
    if (frequency === 'daily') {
      var last = localStorage.getItem(STORAGE_KEY);
      if (!last) return true;
      return (Date.now() - parseInt(last, 10)) > 86400000;
    }
    return true;
  }

  function markSeen(frequency) {
    if (frequency === 'session') sessionStorage.setItem(STORAGE_KEY, '1');
    if (frequency === 'once')    localStorage.setItem(STORAGE_KEY, '1');
    if (frequency === 'daily')   localStorage.setItem(STORAGE_KEY, Date.now().toString());
  }

  function openPopup() {
    var backdrop = document.getElementById('PopupBackdrop');
    var popup    = document.getElementById('PopupNewsletter');
    if (!backdrop || !popup) return;
    backdrop.classList.add('is-open');
    popup.style.display = 'block';
    requestAnimationFrame(function () {
      popup.classList.add('is-open');
    });
    popup.removeAttribute('aria-hidden');
    backdrop.removeAttribute('aria-hidden');
    var firstFocusable = popup.querySelector('input, button');
    if (firstFocusable) firstFocusable.focus();
  }

  function closePopup() {
    var backdrop = document.getElementById('PopupBackdrop');
    var popup    = document.getElementById('PopupNewsletter');
    if (!backdrop || !popup) return;
    popup.classList.remove('is-open');
    backdrop.classList.remove('is-open');
    popup.setAttribute('aria-hidden', 'true');
    backdrop.setAttribute('aria-hidden', 'true');
    setTimeout(function () { popup.style.display = 'none'; }, 350);
  }

  function init() {
    var backdrop = document.getElementById('PopupBackdrop');
    if (!backdrop) return;

    var frequency = backdrop.dataset.frequency || 'session';
    var delay     = parseInt(backdrop.dataset.delay || '3', 10) * 1000;

    if (!shouldShow(frequency)) return;

    setTimeout(function () {
      openPopup();
      markSeen(frequency);
    }, delay);

    document.getElementById('PopupClose').addEventListener('click', closePopup);
    backdrop.addEventListener('click', closePopup);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closePopup();
    });

    var successClose = document.getElementById('PopupSuccessClose');
    if (successClose) successClose.addEventListener('click', closePopup);

    /* ── Copy code button ── */
    var copyBtn = document.getElementById('PopupCopyBtn');
    if (copyBtn) {
      copyBtn.addEventListener('click', function () {
        var code = document.querySelector('.pnl-code');
        if (!code) return;
        navigator.clipboard.writeText(code.textContent.trim()).then(function () {
          copyBtn.textContent = 'Copied!';
          setTimeout(function () { copyBtn.textContent = 'Copy'; }, 2000);
        });
      });
    }

    /* ── Form submission ── */
    var form = document.getElementById('PopupForm');
    if (!form) return;

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var emailInput = document.getElementById('PopupEmail');
      var errorEl    = document.getElementById('PopupError');
      var submitBtn  = document.getElementById('PopupSubmit');
      var email      = emailInput.value.trim();

      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        errorEl.textContent = 'Please enter a valid email address.';
        emailInput.focus();
        return;
      }
      errorEl.textContent = '';
      submitBtn.disabled  = true;
      submitBtn.textContent = 'Subscribing…';

      fetch('/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'form_type=customer&utf8=%E2%9C%93&contact%5Bemail%5D=' + encodeURIComponent(email) + '&contact%5Btags%5D=newsletter'
      })
      .then(function () {
        document.getElementById('PopupFormWrap').style.display = 'none';
        var success = document.getElementById('PopupSuccess');
        success.classList.add('is-visible');
        localStorage.setItem(STORAGE_KEY, frequency === 'daily' ? Date.now().toString() : '1');
      })
      .catch(function () {
        submitBtn.disabled   = false;
        submitBtn.textContent = '{{ section.settings.button_text | default: "Claim Offer" | escape }}';
        errorEl.textContent  = 'Something went wrong. Please try again.';
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  /* Re-init when section is reloaded in Theme Editor */
  document.addEventListener('shopify:section:load', function (e) {
    if (e.detail.sectionId === '{{ section.id }}') init();
  });
})();
</script>

{%- endif -%}

{% schema %}
{
  "name": "Newsletter Popup",
  "tag": "div",
  "class": "section-popup-newsletter",
  "settings": [
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "select",
      "id": "frequency",
      "label": "Show popup",
      "default": "session",
      "options": [
        { "value": "always",  "label": "Every visit / refresh" },
        { "value": "session", "label": "Once per session" },
        { "value": "daily",   "label": "Once per day" },
        { "value": "once",    "label": "First visit only" }
      ]
    },
    {
      "type": "checkbox",
      "id": "homepage_only",
      "label": "Show on homepage only",
      "default": true
    },
    {
      "type": "range",
      "id": "delay",
      "label": "Delay before showing",
      "min": 0,
      "max": 15,
      "step": 1,
      "unit": "s",
      "default": 3
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Side image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Exclusive Offer"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Discover Your Signature Scent"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Subscribe and get 10% off your first order"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Claim Offer"
    },
    {
      "type": "text",
      "id": "fine_print",
      "label": "Fine print",
      "default": "No spam. Unsubscribe anytime."
    },
    {
      "type": "header",
      "content": "Success state"
    },
    {
      "type": "text",
      "id": "success_title",
      "label": "Success heading",
      "default": "You're in!"
    },
    {
      "type": "text",
      "id": "success_sub",
      "label": "Success message",
      "default": "Use the code below at checkout"
    },
    {
      "type": "text",
      "id": "discount_code",
      "label": "Discount code (leave blank to hide)",
      "default": "WELCOME10"
    },
    {
      "type": "text",
      "id": "success_cta",
      "label": "Success button text",
      "default": "Start Shopping"
    }
  ],
  "presets": [
    {
      "name": "Newsletter Popup"
    }
  ]
}
{% endschema %}
