<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  {%- comment -%} Favicon — image is set via Theme Settings > Favicon {%- endcomment -%}
  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" sizes="32x32"
          href="{{ settings.favicon | image_url: width: 32, height: 32, crop: 'center' }}">
    <link rel="icon" type="image/png" sizes="192x192"
          href="{{ settings.favicon | image_url: width: 192, height: 192, crop: 'center' }}">
    <link rel="apple-touch-icon" sizes="180x180"
          href="{{ settings.favicon | image_url: width: 180, height: 180, crop: 'center' }}">
  {%- endif -%}

  <title>
    {%- if template.name == 'index' -%}
      {{- page_title | default: shop.name -}}
      {%- unless page_title contains shop.name %} — Luxury Fragrances{%- endunless -%}
    {%- else -%}
      {{- page_title -}}
      {%- unless page_title contains shop.name %} | {{ shop.name }}{%- endunless -%}
    {%- endif -%}
  </title>

  {%- assign meta_desc = page_description -%}
  {%- if meta_desc == blank and template.name == 'index' -%}
    {%- assign meta_desc = shop.name | append: ' — Discover luxury fragrances crafted for every mood and occasion. Shop new arrivals, seasonal collections and signature scents.' -%}
  {%- endif -%}
  {%- if meta_desc != blank -%}
    <meta name="description" content="{{ meta_desc | truncate: 155 | escape }}">
  {%- endif -%}

  {%- comment -%} Open Graph — improves social sharing previews on WhatsApp, Instagram, etc. {%- endcomment -%}
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:title" content="{{ page_title | default: shop.name | escape }}">
  <meta property="og:description" content="{{ meta_desc | truncate: 155 | escape }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:type" content="{%- if template.name == 'product' -%}product{%- else -%}website{%- endif -%}">
  {%- if page_image -%}
    <meta property="og:image" content="{{ page_image | image_url: width: 1200 }}">
    <meta property="og:image:width" content="1200">
  {%- endif -%}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="theme-color" content="#FAFAF8">

  <link rel="canonical" href="{{ canonical_url }}">

  {%- comment -%} Preconnects FIRST — before any cross-origin request fires {%- endcomment -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  {%- comment -%}
    Non-render-blocking font load — preload fetches the stylesheet immediately
    but doesn't block the first paint. onload swaps it in once downloaded.
    noscript fallback ensures fonts load with JS disabled.
    Variants reduced vs. original: removed Philosopher italic-700, Playfair italic-600, Lato-300 + italics.
  {%- endcomment -%}
  {%- assign gfonts_url = 'https://fonts.googleapis.com/css2?family=Philosopher:ital,wght@0,400;0,700;1,400&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Lato:wght@400;700&display=swap' -%}
  <link rel="preload" href="{{ gfonts_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="{{ gfonts_url }}"></noscript>

  {%- comment -%} LCP hero image preload — homepage only, only when a hero image is set {%- endcomment -%}
  {%- if template.name == 'index' -%}
    {%- assign hero_section_settings = sections['hero'].settings -%}
    {%- if hero_section_settings.hero_image != blank -%}
      <link
        rel="preload"
        as="image"
        imagesrcset="{{ hero_section_settings.hero_image | image_url: width: 400, format: 'webp' }} 400w,
                     {{ hero_section_settings.hero_image | image_url: width: 600, format: 'webp' }} 600w,
                     {{ hero_section_settings.hero_image | image_url: width: 800, format: 'webp' }} 800w,
                     {{ hero_section_settings.hero_image | image_url: width: 1200, format: 'webp' }} 1200w"
        imagesizes="100vw"
        fetchpriority="high"
      >
    {%- endif -%}
  {%- endif -%}

  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
  {%- render 'schema-website' -%}
</head>
<body class="template-{{ template.name }}">

  <a class="skip-to-content" href="#MainContent">Skip to content</a>

  {% section 'header' %}

  <main id="MainContent" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {% section 'popup-newsletter' %}

  <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>

  {%- comment -%} ── Scroll to Top button ── {%- endcomment -%}
  <button
    class="scroll-to-top"
    id="ScrollToTop"
    aria-label="Scroll to top"
    title="Back to top"
  >
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="20" height="20" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5"/>
    </svg>
  </button>
</body>
</html>
