<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <title>
    {{ page_title }}
    {%- unless page_title contains shop.name %} | {{ shop.name }}{% endunless %}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- comment -%} Preconnects FIRST — before any cross-origin request fires {%- endcomment -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  {%- comment -%} Single consolidated font request with display=swap so text renders immediately with fallback font {%- endcomment -%}
  <link href="https://fonts.googleapis.com/css2?family=Philosopher:ital,wght@0,400;0,700;1,400;1,700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Lato:ital,wght@0,300;0,400;0,700;1,300&display=swap" rel="stylesheet">

  {%- comment -%} LCP hero image preload — homepage only, only when a hero image is set {%- endcomment -%}
  {%- if template.name == 'index' -%}
    {%- assign hero_section_settings = sections['hero'].settings -%}
    {%- if hero_section_settings.hero_image != blank -%}
      <link
        rel="preload"
        as="image"
        imagesrcset="{{ hero_section_settings.hero_image | image_url: width: 400, format: 'webp' }} 400w,
                     {{ hero_section_settings.hero_image | image_url: width: 600, format: 'webp' }} 600w,
                     {{ hero_section_settings.hero_image | image_url: width: 800, format: 'webp' }} 800w,
                     {{ hero_section_settings.hero_image | image_url: width: 1200, format: 'webp' }} 1200w"
        imagesizes="100vw"
        fetchpriority="high"
      >
    {%- endif -%}
  {%- endif -%}

  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
  {%- render 'schema-website' -%}
</head>
<body class="template-{{ template.name }}">

  <a class="skip-to-content" href="#MainContent">Skip to content</a>

  {% section 'header' %}

  <main id="MainContent" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>

  {%- comment -%} ── Scroll to Top button ── {%- endcomment -%}
  <button
    class="scroll-to-top"
    id="ScrollToTop"
    aria-label="Scroll to top"
    title="Back to top"
  >
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="20" height="20" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5"/>
    </svg>
  </button>
</body>
</html>
